# .htaccess - TAAGC Global
RewriteEngine On

# Allow direct access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Special rule for admin dashboard - don't redirect to 404
RewriteRule ^admin/dashboard\.html$ - [L]

# All other non-existent files go to 404.html
RewriteRule ^(.*)$ 404.html [L]

# Protect admin directory (optional IP restrictions)
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/admin/
    # Add your IP restriction if needed
    # RewriteCond %{REMOTE_ADDR} !^192\.168\.1\.
    # RewriteRule ^ - [F]
</IfModule>
