# ============================================
# TAAGC GLOBAL - .htaccess CONFIGURATION
# ============================================

# Enable rewrite engine
RewriteEngine On
RewriteBase /

# ============================================
# SECURITY HEADERS
# ============================================

# Prevent directory listings
Options -Indexes

# Protect against XSS attacks
<IfModule mod_headers.c>
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ============================================
# CORS HEADERS FOR API
# ============================================

<IfModule mod_headers.c>
    <FilesMatch "\.(json|js)$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type, Authorization, X-API-Key"
    </FilesMatch>
</IfModule>

# ============================================
# COMPRESSION
# ============================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

# ============================================
# CACHE CONTROL
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    
    # HTML files: no cache (revalidate always)
    ExpiresByType text/html "access plus 0 seconds"
    
    # CSS, JavaScript: 1 year
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Images: 1 year
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # Fonts: 1 year
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
    
    # JSON: 1 hour
    ExpiresByType application/json "access plus 1 hour"
</IfModule>

# ============================================
# URL REWRITING - CLEAN URLs
# ============================================

# Remove trailing slash
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# ============================================
# MAIN ROUTES
# ============================================

# Homepage
RewriteRule ^$ /public/index.html [L]
RewriteRule ^index$ /public/index.html [L]
RewriteRule ^home$ /public/index.html [L]

# Auth pages
RewriteRule ^login$ /public/login.html [L]
RewriteRule ^register$ /public/register.html [L]
RewriteRule ^complete-profile$ /public/complete-profile.html [L]

# Events
RewriteRule ^events$ /public/events.html [L]

# Admin routes
RewriteRule ^admin$ /admin/dashboard.html [L]
RewriteRule ^admin/dashboard$ /admin/dashboard.html [L]
RewriteRule ^admin/setup$ /admin/setup.html [L]

# Admin login (special path)
RewriteRule ^xtaagc/admin-login$ /xtaagc/admin-login.html [L]

# Profile pages
RewriteRule ^profile/client$ /profile/client.html [L]
RewriteRule ^profile/investor$ /profile/investor.html [L]

# API documentation
RewriteRule ^api-docs$ /api-docs.html [L]

# ============================================
# API ROUTES (Passthrough)
# ============================================

# If you're using Apache as a proxy to Vercel, uncomment these lines
# RewriteCond %{REQUEST_URI} ^/api/
# RewriteRule ^api/(.*)$ http://localhost:3000/api/$1 [P,L]

# ============================================
# STATIC ASSETS
# ============================================

# Serve static files directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|pdf)$ - [L]

# ============================================
# ERROR PAGES
# ============================================

ErrorDocument 400 /public/404.html
ErrorDocument 401 /public/404.html
ErrorDocument 403 /public/404.html
ErrorDocument 404 /public/404.html
ErrorDocument 500 /public/500.html

# ============================================
# PROTECT SENSITIVE FILES
# ============================================

# Protect .htaccess itself
<Files ~ "^\.ht">
    Order allow,deny
    Deny from all
</Files>

# Protect .env files
<FilesMatch "^\.env">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect JSON config files
<FilesMatch "\.(json|lock|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect service account keys
<FilesMatch "service-account|firebase-adminsdk">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================
# HTTPS REDIRECT (Force SSL)
# ============================================

RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ============================================
# WWW to NON-WWW (or vice versa)
# ============================================

# Redirect www to non-www
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# ============================================
# BROWSER CACHING
# ============================================

<IfModule mod_headers.c>
    # Cache static assets for 1 year
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|svg|webp|js|css|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    # Cache HTML files for 0 seconds (always revalidate)
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=0, private, must-revalidate"
    </FilesMatch>
    
    # Cache JSON/XML for 1 hour
    <FilesMatch "\.(json|xml)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>
</IfModule>

# ============================================
# CHARACTER SETS
# ============================================

AddDefaultCharset utf-8
AddCharset utf-8 .html .css .js .xml .json .txt

# ============================================
# MIME TYPES
# ============================================

AddType application/javascript .js
AddType text/css .css
AddType text/html .html
AddType application/json .json
AddType image/svg+xml .svg
AddType application/font-woff .woff
AddType application/font-woff2 .woff2
AddType application/x-font-ttf .ttf
AddType application/x-font-opentype .otf

# ============================================
# DISABLE ETAGS (for performance)
# ============================================

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None
