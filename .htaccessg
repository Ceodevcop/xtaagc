# .htaccess - TAAGC Global
RewriteEngine On

# Allow direct access to existing files and directories
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Special rules for admin files - these are in root directory, not /admin/ folder
RewriteRule ^admin\.html$ - [L]
RewriteRule ^admin\dashboard\.html$ - [L]
RewriteRule ^create-admin\.html$ - [L]

# All other non-existent files go to 404.html
RewriteRule ^(.*)$ 404.html [L]

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
