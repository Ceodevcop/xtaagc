<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CEO Setup - TAAGC Global Platform Initialization</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-storage-compat.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0a2540, #1a3a4f);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .setup-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* ===== HEADER ===== */
        .setup-header {
            background: linear-gradient(135deg, #c19a6b, #b38b5f);
            color: white;
            padding: 40px;
            border-radius: 30px 30px 0 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .setup-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 50%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);
        }

        .ceo-crown {
            font-size: 64px;
            margin-bottom: 20px;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }

        .setup-header h1 {
            font-size: 48px;
            margin-bottom: 10px;
            position: relative;
            z-index: 2;
        }

        .setup-header h1 span {
            color: #0a2540;
        }

        .setup-header p {
            font-size: 18px;
            opacity: 0.9;
            position: relative;
            z-index: 2;
        }

        /* ===== PROGRESS BAR ===== */
        .progress-container {
            background: white;
            padding: 20px 40px;
            border-radius: 0 0 30px 30px;
            margin-bottom: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .progress-steps {
            display: flex;
            justify-content: space-between;
            position: relative;
        }

        .progress-steps::before {
            content: '';
            position: absolute;
            top: 20px;
            left: 0;
            width: 100%;
            height: 2px;
            background: #e2e8f0;
            z-index: 1;
        }

        .step {
            position: relative;
            z-index: 2;
            background: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #e2e8f0;
            font-weight: 600;
            color: #64748b;
        }

        .step.active {
            border-color: #c19a6b;
            background: #c19a6b;
            color: white;
        }

        .step.completed {
            border-color: #10b981;
            background: #10b981;
            color: white;
        }

        .step-label {
            position: absolute;
            top: 45px;
            font-size: 12px;
            color: #64748b;
            white-space: nowrap;
        }

        /* ===== MAIN CARD ===== */
        .setup-card {
            background: white;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            margin-bottom: 30px;
        }

        .section-title {
            color: #0a2540;
            font-size: 24px;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 15px;
            border-bottom: 2px solid #c19a6b;
        }

        .section-title i {
            color: #c19a6b;
        }

        /* ===== CEO INFO CARD ===== */
        .ceo-card {
            background: linear-gradient(135deg, #0a2540, #1a3a4f);
            color: white;
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
        }

        .ceo-card::before {
            content: '👑';
            position: absolute;
            bottom: -20px;
            right: -20px;
            font-size: 150px;
            opacity: 0.1;
        }

        .ceo-badge {
            display: inline-block;
            padding: 8px 20px;
            background: #c19a6b;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .ceo-name {
            font-size: 32px;
            margin-bottom: 10px;
        }

        .ceo-email {
            font-size: 18px;
            opacity: 0.9;
            margin-bottom: 20px;
        }

        .ceo-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 30px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #c19a6b;
        }

        .stat-label {
            font-size: 12px;
            opacity: 0.8;
        }

        /* ===== COLLECTIONS GRID ===== */
        .collections-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 15px;
            margin: 20px 0;
        }

        .collection-item {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .collection-icon {
            width: 40px;
            height: 40px;
            background: rgba(193,154,107,0.1);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #c19a6b;
        }

        .collection-name {
            font-weight: 600;
            color: #0a2540;
        }

        .collection-badge {
            margin-left: auto;
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 12px;
            background: #10b981;
            color: white;
        }

        /* ===== PERMISSIONS MATRIX ===== */
        .permissions-matrix {
            background: #f8fafc;
            border-radius: 16px;
            padding: 20px;
            margin: 20px 0;
        }

        .perm-row {
            display: flex;
            align-items: center;
            padding: 10px;
            border-bottom: 1px solid #e2e8f0;
        }

        .perm-row:last-child {
            border-bottom: none;
        }

        .perm-icon {
            width: 30px;
            color: #c19a6b;
        }

        .perm-name {
            width: 200px;
            font-weight: 600;
        }

        .perm-desc {
            flex: 1;
            color: #64748b;
            font-size: 13px;
        }

        .perm-check {
            width: 30px;
            color: #10b981;
        }

        /* ===== FORM ELEMENTS ===== */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #0a2540;
        }

        .form-control {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #e2e8f0;
            border-radius: 12px;
            font-size: 16px;
            transition: all 0.3s;
        }

        .form-control:focus {
            border-color: #c19a6b;
            outline: none;
        }

        .password-field {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            cursor: pointer;
        }

        /* ===== BUTTONS ===== */
        .btn {
            padding: 16px 32px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-primary {
            background: #0a2540;
            color: white;
        }

        .btn-primary:hover {
            background: #1a3a4f;
            transform: translateY(-2px);
        }

        .btn-accent {
            background: #c19a6b;
            color: white;
        }

        .btn-accent:hover {
            background: #b38b5f;
            transform: translateY(-2px);
        }

        .btn-success {
            background: #10b981;
            color: white;
        }

        .btn-success:hover {
            background: #0e9f6e;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* ===== ALERTS ===== */
        .alert {
            padding: 15px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-success {
            background: #dcfce7;
            border: 1px solid #10b981;
            color: #0e9f6e;
        }

        .alert-error {
            background: #fee2e2;
            border: 1px solid #e53e3e;
            color: #c53030;
        }

        .alert-info {
            background: #cff4fc;
            border: 1px solid #0891b2;
            color: #065a82;
        }

        /* ===== SUMMARY CARDS ===== */
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin: 30px 0;
        }

        .summary-card {
            background: #f8fafc;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            border: 1px solid #e2e8f0;
        }

        .summary-number {
            font-size: 32px;
            font-weight: 800;
            color: #c19a6b;
            margin-bottom: 5px;
        }

        .summary-label {
            color: #64748b;
            font-size: 13px;
        }

        /* ===== ACTION BUTTONS ===== */
        .action-buttons {
            display: flex;
            gap: 20px;
            justify-content: flex-end;
            margin-top: 40px;
        }
    </style>
</head>
<body>
    <div class="setup-container">
        <!-- Header -->
        <div class="setup-header">
            <div class="ceo-crown">👑</div>
            <h1><span>TAAGC</span> PLATFORM SETUP</h1>
            <p>Complete Firebase initialization for Super Admin (CEO)</p>
        </div>

        <!-- Progress Bar -->
        <div class="progress-container">
            <div class="progress-steps">
                <div class="step active" id="step1">1</div>
                <div class="step" id="step2">2</div>
                <div class="step" id="step3">3</div>
                <div class="step" id="step4">4</div>
                <div class="step" id="step5">5</div>
                <span class="step-label" style="left: -5px;">CEO Account</span>
                <span class="step-label" style="left: 22%;">Collections</span>
                <span class="step-label" style="left: 44%;">Permissions</span>
                <span class="step-label" style="left: 66%;">Rules</span>
                <span class="step-label" style="right: -5px;">Complete</span>
            </div>
        </div>

        <!-- Main Setup Card -->
        <div class="setup-card">
            <!-- Alert Area -->
            <div id="setupAlert" class="alert" style="display: none;"></div>

            <!-- Step 1: CEO Account Creation -->
            <div id="step1Content">
                <h3 class="section-title"><i class="fas fa-crown"></i> Create Super Admin (CEO) Account</h3>
                
                <div class="ceo-card">
                    <span class="ceo-badge"><i class="fas fa-crown"></i> SUPER ADMIN</span>
                    <h2 class="ceo-name">Ahmad Hamza</h2>
                    <div class="ceo-email">ceo@taagc.website</div>
                    <p>This account will have FULL ACCESS to all collections and permissions. Only one super admin account exists.</p>
                    
                    <div class="ceo-stats">
                        <div class="stat-item">
                            <div class="stat-value">∞</div>
                            <div class="stat-label">Full Access</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">25+</div>
                            <div class="stat-label">Collections</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">100%</div>
                            <div class="stat-label">Permissions</div>
                        </div>
                    </div>
                </div>

                <form id="ceoSetupForm">
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email (Fixed)</label>
                        <input type="email" class="form-control" id="ceoEmail" value="ceo@taagc.website" readonly disabled>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Full Name</label>
                        <input type="text" class="form-control" id="ceoName" value="Ahmad Hamza" readonly disabled>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <div class="password-field">
                            <input type="password" class="form-control" id="ceoPassword" placeholder="Enter secure password" required>
                            <i class="fas fa-eye toggle-password" onclick="togglePassword('ceoPassword')"></i>
                        </div>
                        <small style="color: #64748b;">Minimum 8 characters with 1 number and 1 special character</small>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Confirm Password</label>
                        <div class="password-field">
                            <input type="password" class="form-control" id="ceoConfirmPassword" placeholder="Confirm password" required>
                            <i class="fas fa-eye toggle-password" onclick="togglePassword('ceoConfirmPassword')"></i>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="checkbox">
                            <input type="checkbox" id="agreeTerms" required>
                            <span>I confirm that this account will be the SUPER ADMIN with full system access</span>
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary" id="createCeoBtn">
                        <i class="fas fa-crown"></i> Create Super Admin Account
                    </button>
                </form>
            </div>

            <!-- Step 2: Collections Overview -->
            <div id="step2Content" style="display: none;">
                <h3 class="section-title"><i class="fas fa-database"></i> Firebase Collections to Create</h3>
                
                <p style="color: #64748b; margin-bottom: 20px;">The following collections will be created with full access for the CEO (Super Admin):</p>

                <div class="collections-grid">
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-users"></i></div>
                        <span class="collection-name">users</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-user-shield"></i></div>
                        <span class="collection-name">admins</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-user-tie"></i></div>
                        <span class="collection-name">staff</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-chart-line"></i></div>
                        <span class="collection-name">investors</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-building"></i></div>
                        <span class="collection-name">investments</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-exchange-alt"></i></div>
                        <span class="collection-name">transactions</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-university"></i></div>
                        <span class="collection-name">banks</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-building"></i></div>
                        <span class="collection-name">agencies</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-calendar"></i></div>
                        <span class="collection-name">events</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-file-contract"></i></div>
                        <span class="collection-name">contracts</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-percent"></i></div>
                        <span class="collection-name">commissions</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-key"></i></div>
                        <span class="collection-name">api_keys</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-cog"></i></div>
                        <span class="collection-name">settings</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-history"></i></div>
                        <span class="collection-name">activity_logs</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-shield-alt"></i></div>
                        <span class="collection-name">security</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-globe"></i></div>
                        <span class="collection-name">subdomains</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-folder"></i></div>
                        <span class="collection-name">projects</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-code"></i></div>
                        <span class="collection-name">api_endpoints</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-store"></i></div>
                        <span class="collection-name">marketplace</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                    <div class="collection-item">
                        <div class="collection-icon"><i class="fas fa-comments"></i></div>
                        <span class="collection-name">chats</span>
                        <span class="collection-badge">CEO</span>
                    </div>
                </div>

                <div class="summary-grid">
                    <div class="summary-card">
                        <div class="summary-number">20</div>
                        <div class="summary-label">Collections</div>
                    </div>
                    <div class="summary-card">
                        <div class="summary-number">∞</div>
                        <div class="summary-label">CEO Access</div>
                    </div>
                    <div class="summary-card">
                        <div class="summary-number">100%</div>
                        <div class="summary-label">Permissions</div>
                    </div>
                    <div class="summary-card">
                        <div class="summary-number">24/7</div>
                        <div class="summary-label">Uptime</div>
                    </div>
                </div>

                <button class="btn btn-accent" onclick="nextStep(3)">
                    Continue to Permissions <i class="fas fa-arrow-right"></i>
                </button>
            </div>

            <!-- Step 3: Permissions Matrix -->
            <div id="step3Content" style="display: none;">
                <h3 class="section-title"><i class="fas fa-shield-alt"></i> CEO Permissions Matrix</h3>
                
                <p style="color: #64748b; margin-bottom: 20px;">The CEO (Super Admin) will have FULL permissions on ALL collections:</p>

                <div class="permissions-matrix">
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">users</div>
                        <div class="perm-desc">Create, Read, Update, Delete all users</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">admins</div>
                        <div class="perm-desc">Create, manage, delete all admin accounts</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">staff</div>
                        <div class="perm-desc">Full HR management, payroll, schedules</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">investors</div>
                        <div class="perm-desc">Full investor management, portfolios</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">investments</div>
                        <div class="perm-desc">Create, approve, manage all investments</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">transactions</div>
                        <div class="perm-desc">View and manage all transactions</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">banks</div>
                        <div class="perm-desc">Connect, manage, reconcile all banks</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">agencies</div>
                        <div class="perm-desc">Full agency management, commissions</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">events</div>
                        <div class="perm-desc">Create and manage all events</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">settings</div>
                        <div class="perm-desc">System-wide settings and configuration</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">api_keys</div>
                        <div class="perm-desc">Generate, revoke, manage all API keys</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                    <div class="perm-row">
                        <div class="perm-icon"><i class="fas fa-check-circle" style="color: #10b981;"></i></div>
                        <div class="perm-name">subdomains</div>
                        <div class="perm-desc">Create and manage all subdomains</div>
                        <div class="perm-check">✅ FULL</div>
                    </div>
                </div>

                <button class="btn btn-accent" onclick="nextStep(4)">
                    Continue to Security Rules <i class="fas fa-arrow-right"></i>
                </button>
            </div>

            <!-- Step 4: Security Rules -->
            <div id="step4Content" style="display: none;">
                <h3 class="section-title"><i class="fas fa-shield-alt"></i> Firestore Security Rules</h3>
                
                <p style="color: #64748b; margin-bottom: 20px;">The following security rules will be applied:</p>

                <pre style="background: #1e293b; color: #c19a6b; padding: 20px; border-radius: 12px; overflow-x: auto; margin-bottom: 30px;">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 🔥 CEO (Super Admin) has FULL access to everything
    match /{document=**} {
      allow read, write: if request.auth != null && 
        request.auth.token.role == 'super_admin';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || 
         request.auth.token.role == 'super_admin');
    }
    
    // Admins collection (CEO only)
    match /admins/{adminId} {
      allow read, write: if request.auth != null && 
        request.auth.token.role == 'super_admin';
    }
    
    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.role == 'super_admin';
    }
  }
}
                </pre>

                <button class="btn btn-accent" onclick="nextStep(5)">
                    Continue to Complete Setup <i class="fas fa-arrow-right"></i>
                </button>
            </div>

            <!-- Step 5: Complete -->
            <div id="step5Content" style="display: none;">
                <div style="text-align: center; padding: 40px;">
                    <i class="fas fa-check-circle" style="font-size: 80px; color: #10b981; margin-bottom: 20px;"></i>
                    <h2 style="color: #0a2540; margin-bottom: 20px;">Ready to Complete Setup!</h2>
                    <p style="color: #64748b; margin-bottom: 30px;">All configurations are ready. Click the button below to initialize your Firebase platform with CEO super admin access.</p>
                    
                    <div class="summary-grid">
                        <div class="summary-card">
                            <div class="summary-number">20</div>
                            <div class="summary-label">Collections</div>
                        </div>
                        <div class="summary-card">
                            <div class="summary-number">1</div>
                            <div class="summary-label">Super Admin</div>
                        </div>
                        <div class="summary-card">
                            <div class="summary-number">100%</div>
                            <div class="summary-label">Permissions</div>
                        </div>
                        <div class="summary-card">
                            <div class="summary-number">∞</div>
                            <div class="summary-label">Access</div>
                        </div>
                    </div>

                    <button class="btn btn-success" id="completeSetupBtn" onclick="completeSetup()" style="font-size: 18px; padding: 20px 40px;">
                        <i class="fas fa-crown"></i> Initialize Platform with CEO Access
                    </button>
                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="action-buttons">
                <button class="btn btn-outline" id="prevBtn" onclick="prevStep()" style="display: none;">
                    <i class="fas fa-arrow-left"></i> Previous
                </button>
                <button class="btn btn-primary" id="nextBtn" onclick="nextStep()">
                    Next <i class="fas fa-arrow-right"></i>
                </button>
            </div>
        </div>

        <!-- Footer -->
        <div style="text-align: center; color: white; opacity: 0.7; margin-top: 20px;">
            <p>© 2025 TAAGC Global. CEO Platform Setup v2.0</p>
        </div>
    </div>

    <script>
        // ============================================
        // FIREBASE CONFIGURATION
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyCOcCDPqRSlAMJJBEeNchTA1qO9tl9Nldw",
            authDomain: "xtaagc.firebaseapp.com",
            projectId: "xtaagc",
            storageBucket: "xtaagc.appspot.com",
            messagingSenderId: "256073982437",
            appId: "1:256073982437:web:8da63bb7acc86c0ca98f0c"
        };

        // Initialize Firebase
        if (!firebase.apps.length) {
            firebase.initializeApp(firebaseConfig);
            console.log('🔥 Firebase initialized');
        }

        const auth = firebase.auth();
        const db = firebase.firestore();

        // ============================================
        // STATE MANAGEMENT
        // ============================================
        let currentStep = 1;
        let ceoUser = null;

        // ============================================
        // TOGGLE PASSWORD
        // ============================================
        window.togglePassword = function(inputId) {
            const input = document.getElementById(inputId);
            const icon = event.currentTarget;
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        };

        // ============================================
        // STEP NAVIGATION
        // ============================================
        let currentStep = 1;

        function updateStep(step) {
            // Hide all step content
            for (let i = 1; i <= 5; i++) {
                document.getElementById(`step${i}Content`).style.display = 'none';
            }
            
            // Show current step
            document.getElementById(`step${step}Content`).style.display = 'block';
            
            // Update step indicators
            for (let i = 1; i <= 5; i++) {
                const stepEl = document.getElementById(`step${i}`);
                stepEl.classList.remove('active', 'completed');
                
                if (i < step) {
                    stepEl.classList.add('completed');
                } else if (i === step) {
                    stepEl.classList.add('active');
                }
            }
            
            // Update navigation buttons
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            
            prevBtn.style.display = step === 1 ? 'none' : 'inline-flex';
            nextBtn.style.display = step === 5 ? 'none' : 'inline-flex';
        }

        window.nextStep = function(targetStep = null) {
            if (targetStep) {
                currentStep = targetStep;
            } else {
                currentStep++;
            }
            updateStep(currentStep);
        };

        window.prevStep = function() {
            currentStep--;
            updateStep(currentStep);
        };

        // ============================================
        // SHOW ALERT
        // ============================================
        function showAlert(message, type) {
            const alert = document.getElementById('setupAlert');
            alert.className = `alert alert-${type}`;
            alert.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${message}`;
            alert.style.display = 'flex';
            
            setTimeout(() => {
                alert.style.display = 'none';
            }, 5000);
        }

        // ============================================
        // STEP 1: CREATE CEO ACCOUNT
        // ============================================
        document.getElementById('ceoSetupForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const password = document.getElementById('ceoPassword').value;
            const confirmPassword = document.getElementById('ceoConfirmPassword').value;
            const createBtn = document.getElementById('createCeoBtn');
            
            // Validate password
            if (password !== confirmPassword) {
                showAlert('Passwords do not match', 'error');
                return;
            }
            
            if (password.length < 8) {
                showAlert('Password must be at least 8 characters', 'error');
                return;
            }

            try {
                createBtn.innerHTML = '<span class="spinner"></span> Creating Super Admin...';
                createBtn.disabled = true;

                // Check if CEO already exists
                const existingSnapshot = await db.collection('users').where('email', '==', 'ceo@taagc.website').get();
                
                if (!existingSnapshot.empty) {
                    showAlert('CEO account already exists!', 'info');
                    currentStep = 3;
                    updateStep(3);
                    return;
                }

                // Create auth user
                const userCred = await auth.createUserWithEmailAndPassword('ceo@taagc.website', password);
                ceoUser = userCred.user;
                
                // Update profile
                await ceoUser.updateProfile({
                    displayName: 'Ahmad Hamza'
                });

                // Create CEO document with ALL permissions
                const ceoData = {
                    uid: ceoUser.uid,
                    email: 'ceo@taagc.website',
                    fullName: 'Ahmad Hamza',
                    role: 'super_admin',
                    status: 'active',
                    permissions: {
                        users: { create: true, read: true, update: true, delete: true },
                        admins: { create: true, read: true, update: true, delete: true },
                        staff: { create: true, read: true, update: true, delete: true },
                        investors: { create: true, read: true, update: true, delete: true },
                        investments: { create: true, read: true, update: true, delete: true },
                        transactions: { create: true, read: true, update: true, delete: true },
                        banks: { create: true, read: true, update: true, delete: true },
                        agencies: { create: true, read: true, update: true, delete: true },
                        events: { create: true, read: true, update: true, delete: true },
                        contracts: { create: true, read: true, update: true, delete: true },
                        commissions: { create: true, read: true, update: true, delete: true },
                        api_keys: { create: true, read: true, update: true, delete: true },
                        settings: { create: true, read: true, update: true, delete: true },
                        subdomains: { create: true, read: true, update: true, delete: true },
                        projects: { create: true, read: true, update: true, delete: true },
                        api_endpoints: { create: true, read: true, update: true, delete: true },
                        marketplace: { create: true, read: true, update: true, delete: true },
                        chats: { create: true, read: true, update: true, delete: true },
                        activity_logs: { create: true, read: true, update: true, delete: true },
                        security: { create: true, read: true, update: true, delete: true }
                    },
                    generatedId: 'CEO-001',
                    emailVerified: false,
                    createdAt: firebase.firestore.FieldValue.serverTimestamp(),
                    lastActive: firebase.firestore.FieldValue.serverTimestamp(),
                    metadata: {
                        isCEO: true,
                        superAdmin: true,
                        setupCompleted: false
                    }
                };

                await db.collection('users').doc(ceoUser.uid).set(ceoData);

                showAlert('CEO account created successfully!', 'success');
                
                // Move to next step
                setTimeout(() => {
                    currentStep = 2;
                    updateStep(2);
                }, 1500);

            } catch (error) {
                console.error('Setup error:', error);
                showAlert(error.message, 'error');
                createBtn.innerHTML = '<i class="fas fa-crown"></i> Create Super Admin Account';
                createBtn.disabled = false;
            }
        });

        // ============================================
        // STEP 5: COMPLETE SETUP
        // ============================================
        async function completeSetup() {
            const completeBtn = document.getElementById('completeSetupBtn');
            
            try {
                completeBtn.innerHTML = '<span class="spinner"></span> Initializing Platform...';
                completeBtn.disabled = true;

                // Get CEO user
                const ceoUser = auth.currentUser;
                if (!ceoUser) {
                    showAlert('Please login first', 'error');
                    return;
                }

                // Create initial collections structure
                const collections = [
                    'users', 'admins', 'staff', 'investors', 'investments', 
                    'transactions', 'banks', 'agencies', 'events', 'contracts',
                    'commissions', 'api_keys', 'settings', 'subdomains', 'projects',
                    'api_endpoints', 'marketplace', 'chats', 'activity_logs', 'security'
                ];

                // Create a placeholder document in each collection to initialize them
                const batch = db.batch();
                
                collections.forEach(collection => {
                    const docRef = db.collection(collection).doc('_setup_placeholder');
                    batch.set(docRef, {
                        _createdBy: ceoUser.uid,
                        _createdAt: firebase.firestore.FieldValue.serverTimestamp(),
                        _isPlaceholder: true
                    });
                });

                await batch.commit();

                // Mark CEO setup as complete
                await db.collection('users').doc(ceoUser.uid).update({
                    'metadata.setupCompleted': true,
                    setupCompletedAt: firebase.firestore.FieldValue.serverTimestamp()
                });

                // Create initial settings
                await db.collection('settings').doc('platform').set({
                    name: 'TAAGC Global',
                    version: '2.0.0',
                    ceo: {
                        uid: ceoUser.uid,
                        email: 'ceo@taagc.website',
                        name: 'Ahmad Hamza'
                    },
                    initializedAt: firebase.firestore.FieldValue.serverTimestamp(),
                    collections: collections
                });

                showAlert('✅ Platform initialization complete!', 'success');
                
                setTimeout(() => {
                    window.location.href = '/ceo-dashboard.html';
                }, 2000);

            } catch (error) {
                console.error('Setup completion error:', error);
                showAlert(error.message, 'error');
                completeBtn.innerHTML = '<i class="fas fa-crown"></i> Initialize Platform with CEO Access';
                completeBtn.disabled = false;
            }
        }

        // ============================================
        // INITIALIZE
        // ============================================
        updateStep(1);
    </script>
</body>
</html>
