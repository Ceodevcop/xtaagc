<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super Admin Dashboard | TAAGC Global</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="css/admin.css">
</head>
<body>
    <div class="dashboard">
        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">A</div>
                <div class="logo-text"><span>TAAGC</span> ADMIN</div>
            </div>
            
            <div class="admin-profile">
                <div style="display:flex; align-items:center; gap:12px;">
                    <div class="admin-avatar" id="adminInitials">AH</div>
                    <div>
                        <div id="adminName" style="font-weight:600;">Ahmad Hamza</div>
                        <div id="adminRole" style="font-size:12px; opacity:0.8;">Super Administrator</div>
                    </div>
                </div>
            </div>
            
            <!-- MAIN NAVIGATION -->
            <div class="nav-section">
                <div class="nav-section-title">Main</div>
                <div class="nav-item active" data-page="dashboard">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </div>
                <div class="nav-item" data-page="pages">
                    <i class="fas fa-file-alt"></i> Page Creator
                </div>
            </div>
            
            <div class="nav-section">
                <div class="nav-section-title">Management</div>
                <div class="nav-item" data-page="users">
                    <i class="fas fa-users"></i> Users
                </div>
                <div class="nav-item" data-page="companies">
                    <i class="fas fa-building"></i> Companies
                </div>
                <div class="nav-item" data-page="admins">
                    <i class="fas fa-user-shield"></i> Administrators
                </div>
            </div>
            
            <div class="nav-section">
                <div class="nav-section-title">Commerce</div>
                <div class="nav-item" data-page="orders">
                    <i class="fas fa-shopping-cart"></i> Orders
                </div>
                <div class="nav-item" data-page="investments">
                    <i class="fas fa-chart-line"></i> Investments
                </div>
                <div class="nav-item" data-page="support">
                    <i class="fas fa-headset"></i> Support
                </div>
            </div>
            
            <div class="nav-section">
                <div class="nav-section-title">System</div>
                <div class="nav-item" data-page="analytics">
                    <i class="fas fa-chart-pie"></i> Analytics
                </div>
                <div class="nav-item" data-page="settings">
                    <i class="fas fa-cog"></i> Settings
                </div>
            </div>
            
            <div style="margin-top:50px;">
                <button id="logoutBtn" style="width:100%; padding:12px; background:rgba(255,255,255,0.1); color:white; border:none; border-radius:8px; display:flex; align-items:center; justify-content:center; gap:8px; cursor:pointer;">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </div>
        </div>
        
        <!-- MAIN CONTENT - DYNAMICALLY INJECTED -->
        <div class="main-content" id="mainContent">
            <div class="loading-screen">
                <div class="loading"></div>
                <div style="margin-top:20px; color:#64748b;">Loading dashboard...</div>
            </div>
        </div>
    </div>

    <!-- SCRIPTS - ORDER MATTERS -->
    <script type="module" src="js/firebase-init.js"></script>
    <script type="module" src="js/components/notifications.js"></script>
    <script type="module" src="js/components/modal.js"></script>
    <script type="module" src="js/components/table.js"></script>
    <script type="module" src="js/admin-core.js"></script>
    
    <!-- PAGE MODULES - LOADED DYNAMICALLY BY CORE -->
</body>
</html>
