    <script>
        // ============================================
        // FIREBASE CONFIGURATION
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyCOcCDPqRSlAMJJBEeNchTA1qO9tl9Nldw",
            authDomain: "xtaagc.firebaseapp.com",
            projectId: "xtaagc",
            storageBucket: "xtaagc.appspot.com",
            messagingSenderId: "256073982437",
            appId: "1:256073982437:web:8da63bb7acc86c0ca98f0c"
        };

        // Initialize Firebase
        let app, auth, db;
        try {
            if (!firebase.apps.length) {
                app = firebase.initializeApp(firebaseConfig);
            }
            auth = firebase.auth();
            db = firebase.firestore();
        } catch (error) {
            console.error('Firebase init error:', error);
        }

        // ============================================
        // STATE MANAGEMENT
        // ============================================
        let currentSection = 'dashboard';
        let currentUser = null;

        // ============================================
        // INITIALIZATION
        // ============================================
        document.addEventListener('DOMContentLoaded', async () => {
            updateDate();
            await checkAuth();
        });

        function updateDate() {
            const date = new Date();
            document.getElementById('currentDate').textContent = date.toLocaleDateString('en-US', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });
        }

        // ============================================
        // AUTHENTICATION
        // ============================================
        async function checkAuth() {
            return new Promise((resolve) => {
                auth.onAuthStateChanged(async (user) => {
                    if (user) {
                        currentUser = user;
                        
                        // Get user data
                        const userDoc = await db.collection('users').doc(user.uid).get();
                        
                        if (userDoc.exists) {
                            const userData = userDoc.data();
                            
                            // Check if super_admin
                            if (userData.role !== 'super_admin') {
                                window.location.href = '/dashboard/';
                                return;
                            }
                            
                            // Update UI
                            document.getElementById('userName').textContent = userData.fullName || 'Ahmad Hamza';
                            document.getElementById('userEmail').textContent = user.email;
                            document.getElementById('welcomeName').textContent = userData.fullName || 'Ahmad Hamza';
                            document.getElementById('userAvatar').textContent = 
                                (userData.fullName || 'AH').charAt(0).toUpperCase() + 
                                ((userData.fullName || '').split(' ')[1]?.charAt(0) || 'H');
                        }
                        
                        resolve(true);
                    } else {
                        window.location.href = '/';
                        resolve(false);
                    }
                });
            });
        }

        // ============================================
        // NAVIGATION
        // ============================================
        function showSection(section) {
            currentSection = section;
            
            // Update active nav item
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.remove('active');
            });
            event.currentTarget.classList.add('active');

            // Hide all sections
            document.getElementById('dashboardSection').style.display = 'none';
            document.getElementById('subdomainsSection').style.display = 'none';
            document.getElementById('projectsSection').style.display = 'none';
            document.getElementById('modulesSection').style.display = 'none';
            document.getElementById('apiSection').style.display = 'none';
            document.getElementById('rolesSection').style.display = 'none';
            
            // Show selected section
            document.getElementById(section + 'Section').style.display = 'block';
            
            // Update title
            const titles = {
                dashboard: 'Dashboard',
                subdomains: 'Subdomain Manager',
                projects: 'Project Creator',
                modules: 'Module Installer',
                api: 'API Manager',
                roles: 'User Roles Manager'
            };
            
            document.getElementById('pageTitle').textContent = titles[section] || section;
            document.getElementById('pageSubtitle').textContent = `Manage your ${titles[section] || section}`;
        }

        // ============================================
        // MODAL HANDLING
        // ============================================
        function openModal(modalId) {
            document.getElementById(modalId).classList.add('active');
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // ============================================
        // CREATE FUNCTIONS
        // ============================================
        function createSubdomain(e) {
            e.preventDefault();
            showAlert('Subdomain created successfully!', 'success');
            closeModal('createSubdomainModal');
        }

        function createProject(e) {
            e.preventDefault();
            showAlert('Project created successfully!', 'success');
            closeModal('createProjectModal');
        }

        function createApi(e) {
            e.preventDefault();
            showAlert('API endpoint created successfully!', 'success');
            closeModal('createApiModal');
        }

        function createRole(e) {
            e.preventDefault();
            showAlert('Role created successfully!', 'success');
            closeModal('createRoleModal');
        }

        // ============================================
        // SUBDOMAIN FUNCTIONS
        // ============================================
        function configureSubdomain(name) {
            showAlert(`Configuring subdomain: ${name}.taagc.website`, 'success');
        }

        function deleteSubdomain(name) {
            if (confirm(`Are you sure you want to delete ${name}.taagc.website?`)) {
                showAlert(`Subdomain ${name} deleted`, 'success');
            }
        }

        function refreshSubdomains() {
            showAlert('Refreshing subdomains...', 'success');
        }

        // ============================================
        // PROJECT FUNCTIONS
        // ============================================
        function editProject(name) {
            showAlert(`Editing project: ${name}`, 'success');
        }

        function deployProject(name) {
            showAlert(`Deploying project: ${name}`, 'success');
        }

        function deleteProject(name) {
            if (confirm(`Are you sure you want to delete ${name} project?`)) {
                showAlert(`Project ${name} deleted`, 'success');
            }
        }

        function refreshProjects() {
            showAlert('Refreshing projects...', 'success');
        }

        // ============================================
        // API FUNCTIONS
        // ============================================
        function editApi(name) {
            showAlert(`Editing API: ${name}`, 'success');
        }

        function testApi(name) {
            showAlert(`Testing API: ${name} - Success!`, 'success');
        }

        function deleteApi(name) {
            if (confirm(`Are you sure you want to delete this API endpoint?`)) {
                showAlert(`API endpoint deleted`, 'success');
            }
        }

        function refreshApis() {
            showAlert('Refreshing APIs...', 'success');
        }

        function filterApis(method) {
            document.querySelectorAll('.api-filter-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            showAlert(`Filtering by ${method.toUpperCase()} methods`, 'success');
        }

        // ============================================
        // ROLE FUNCTIONS
        // ============================================
        function editRole(role) {
            showAlert(`Editing role: ${role}`, 'success');
        }

        function viewRole(role) {
            showAlert(`Viewing role: ${role}`, 'success');
        }

        function refreshRoles() {
            showAlert('Refreshing roles...', 'success');
        }

        // ============================================
        // MODULE FUNCTIONS
        // ============================================
        function configureModule(module) {
            showAlert(`Configuring module: ${module}`, 'success');
        }

        function installModule(module) {
            showAlert(`Installing module: ${module}...`, 'success');
        }

        function uninstallModule(module) {
            if (confirm(`Are you sure you want to uninstall ${module} module?`)) {
                showAlert(`Module ${module} uninstalled`, 'success');
            }
        }

        // ============================================
        // ALERT
        // ============================================
        function showAlert(message, type) {
            const alert = document.getElementById('dashboardAlert');
            alert.className = `alert alert-${type}`;
            alert.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'info-circle'}"></i> ${message}`;
            alert.style.display = 'flex';
            
            setTimeout(() => {
                alert.style.display = 'none';
            }, 3000);
        }

        // ============================================
        // LOGOUT
        // ============================================
        window.logout = async function() {
            try {
                await auth.signOut();
                localStorage.removeItem('adminToken');
                localStorage.removeItem('adminUser');
                sessionStorage.clear();
                window.location.href = '/';
            } catch (error) {
                console.error('Logout error:', error);
                window.location.href = '/';
            }
        };

        // Close modal when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('active');
            }
        };
    </script>
</body>
</html>
