<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TAAGC Admin Login</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore-compat.js"></script>
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(135deg, #0a2540, #1a3a4f);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-wrapper {
            width: 100%;
            max-width: 450px;
        }

        /* CEO Badge */
        .ceo-badge {
            background: linear-gradient(135deg, #c19a6b, #b38b5f);
            color: white;
            padding: 8px 20px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(193,154,107,0.3);
        }

        .ceo-badge i {
            font-size: 16px;
        }

        /* Login Card */
        .login-card {
            background: white;
            border-radius: 30px;
            padding: 50px 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            animation: slideUp 0.5s ease;
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .logo-icon {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #0a2540, #1a3a4f);
            border-radius: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: #c19a6b;
            font-size: 40px;
            font-weight: 800;
            box-shadow: 0 10px 20px rgba(10,37,64,0.2);
        }

        .logo h1 {
            font-size: 32px;
            color: #0a2540;
            margin-bottom: 5px;
        }

        .logo h1 span {
            color: #c19a6b;
        }

        .logo p {
            color: #64748b;
            font-size: 15px;
        }

        /* Alert */
        .alert {
            padding: 15px 20px;
            border-radius: 15px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 14px;
            display: none;
        }

        .alert-success {
            background: #dcfce7;
            border: 1px solid #10b981;
            color: #0e9f6e;
        }

        .alert-error {
            background: #fee2e2;
            border: 1px solid #e53e3e;
            color: #c53030;
        }

        .alert-warning {
            background: #fff3cd;
            border: 1px solid #f59e0b;
            color: #856404;
        }

        .alert-info {
            background: #cff4fc;
            border: 1px solid #0891b2;
            color: #065a82;
        }

        /* Form */
        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #1e293b;
            font-weight: 600;
            font-size: 14px;
        }

        .form-group label i {
            color: #c19a6b;
            margin-right: 8px;
            width: 18px;
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            font-size: 16px;
        }

        .form-control {
            width: 100%;
            padding: 16px 20px 16px 50px;
            border: 2px solid #e2e8f0;
            border-radius: 15px;
            font-size: 15px;
            transition: all 0.3s;
        }

        .form-control:focus {
            border-color: #c19a6b;
            outline: none;
            box-shadow: 0 0 0 4px rgba(193,154,107,0.1);
        }

        .password-wrapper {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #64748b;
            cursor: pointer;
            font-size: 18px;
            transition: color 0.3s;
        }

        .password-toggle:hover {
            color: #c19a6b;
        }

        /* Options */
        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .checkbox {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: 14px;
            cursor: pointer;
        }

        .checkbox input {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #c19a6b;
        }

        .forgot-link {
            color: #c19a6b;
            text-decoration: none;
            font-size: 14px;
            font-weight: 600;
        }

        .forgot-link:hover {
            text-decoration: underline;
        }

        /* Buttons */
        .btn-login {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #0a2540, #1a3a4f);
            color: white;
            border: none;
            border-radius: 15px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
        }

        .btn-login::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            transition: left 0.5s;
        }

        .btn-login:hover:not(:disabled)::before {
            left: 100%;
        }

        .btn-login:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(10,37,64,0.3);
        }

        .btn-login:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Setup Link */
        .setup-link {
            text-align: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
        }

        .setup-link p {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 10px;
        }

        .setup-link a {
            color: #c19a6b;
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: rgba(193,154,107,0.1);
            border-radius: 30px;
            transition: all 0.3s;
        }

        .setup-link a:hover {
            background: #c19a6b;
            color: white;
            transform: translateY(-2px);
        }

        .setup-link a i {
            font-size: 16px;
        }

        /* Status */
        .login-status {
            text-align: center;
            margin-top: 20px;
            font-size: 13px;
            color: #64748b;
        }

        .login-status i {
            color: #c19a6b;
            margin-right: 5px;
        }

        /* CEO Highlight */
        .ceo-highlight {
            background: rgba(193,154,107,0.1);
            border: 1px solid #c19a6b;
            border-radius: 12px;
            padding: 12px;
            margin-top: 20px;
            font-size: 13px;
            color: #0a2540;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ceo-highlight i {
            color: #c19a6b;
            font-size: 16px;
        }

        .ceo-highlight strong {
            color: #c19a6b;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- CEO Badge -->
        <div class="ceo-badge">
            <i class="fas fa-crown"></i>
            <span>Super Admin Access</span>
        </div>

        <!-- Login Card -->
        <div class="login-card">
            <div class="logo">
                <div class="logo-icon">
                    <i class="fas fa-crown"></i>
                </div>
                <h1><span>TAAGC</span> ADMIN</h1>
                <p>Secure administrator access</p>
            </div>

            <!-- Alert -->
            <div id="loginAlert" class="alert"></div>

            <!-- Login Form -->
            <form id="loginForm">
                <div class="form-group">
                    <label>
                        <i class="fas fa-envelope"></i>
                        Email Address
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" class="form-control" id="email" value="ceo@taagc.website" placeholder="Enter your email" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>
                        <i class="fas fa-lock"></i>
                        Password
                    </label>
                    <div class="password-wrapper">
                        <div class="input-wrapper">
                            <i class="fas fa-key"></i>
                            <input type="password" class="form-control" id="password" placeholder="Enter your password" required>
                        </div>
                        <i class="fas fa-eye password-toggle" id="togglePassword" onclick="togglePassword()"></i>
                    </div>
                </div>

                <div class="form-options">
                    <label class="checkbox">
                        <input type="checkbox" id="rememberMe" checked>
                        <span>Remember me</span>
                    </label>
                    <a href="#" class="forgot-link" onclick="handleForgotPassword(event)">
                        <i class="fas fa-question-circle"></i> Forgot Password?
                    </a>
                </div>

                <button type="submit" class="btn-login" id="loginBtn">
                    <i class="fas fa-sign-in-alt"></i>
                    Login to Dashboard
                </button>
            </form>

            <!-- Setup Link -->
            <div class="setup-link">
                <p>First time setting up the platform?</p>
                <a href="/ceo-setup.html">
                    <i class="fas fa-crown"></i>
                    Run CEO Platform Setup
                </a>
            </div>

            <!-- Status -->
            <div class="login-status">
                <i class="fas fa-circle"></i>
                <span id="connectionStatus">Checking connection...</span>
            </div>

            <!-- CEO Highlight -->
            <div class="ceo-highlight">
                <i class="fas fa-crown"></i>
                <div>
                    <strong>CEO Super Admin:</strong> ceo@taagc.website has full system access to all collections.
                </div>
            </div>
        </div>
    </div>

    <script>
        // ============================================
        // FIREBASE CONFIGURATION
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyCOcCDPqRSlAMJJBEeNchTA1qO9tl9Nldw",
            authDomain: "xtaagc.firebaseapp.com",
            projectId: "xtaagc",
            storageBucket: "xtaagc.appspot.com",
            messagingSenderId: "256073982437",
            appId: "1:256073982437:web:8da63bb7acc86c0ca98f0c"
        };

        // Initialize Firebase
        let app, auth, db;
        try {
            if (!firebase.apps.length) {
                app = firebase.initializeApp(firebaseConfig);
                console.log('✅ Firebase initialized');
            } else {
                app = firebase.app();
            }
            auth = firebase.auth();
            db = firebase.firestore();
            
            // Update connection status
            document.getElementById('connectionStatus').innerHTML = '✅ Connected to Firebase';
        } catch (error) {
            console.error('❌ Firebase init error:', error);
            document.getElementById('connectionStatus').innerHTML = '❌ Connection failed';
        }

        // ============================================
        // PASSWORD TOGGLE
        // ============================================
        window.togglePassword = function() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('togglePassword');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        };

        // ============================================
        // SHOW ALERT
        // ============================================
        function showAlert(message, type) {
            const alert = document.getElementById('loginAlert');
            alert.className = `alert alert-${type}`;
            
            const icons = {
                success: 'check-circle',
                error: 'exclamation-circle',
                warning: 'exclamation-triangle',
                info: 'info-circle'
            };
            
            alert.innerHTML = `<i class="fas fa-${icons[type]}"></i> ${message}`;
            alert.style.display = 'flex';
            
            setTimeout(() => {
                alert.style.display = 'none';
            }, 5000);
        }

        // ============================================
        // FORGOT PASSWORD
        // ============================================
        window.handleForgotPassword = async function(e) {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            
            if (!email) {
                showAlert('Please enter your email', 'warning');
                return;
            }

            try {
                await auth.sendPasswordResetEmail(email);
                showAlert('Password reset email sent! Check your inbox.', 'success');
            } catch (error) {
                console.error('Reset error:', error);
                showAlert(error.message, 'error');
            }
        };

        // ============================================
        // LOGIN FUNCTION
        // ============================================
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const rememberMe = document.getElementById('rememberMe').checked;
            const loginBtn = document.getElementById('loginBtn');
            
            try {
                // Show loading
                loginBtn.innerHTML = '<span class="spinner"></span> Authenticating...';
                loginBtn.disabled = true;

                console.log('🔐 Login attempt for:', email);

                // Set persistence
                await auth.setPersistence(
                    rememberMe ? 
                    firebase.auth.Auth.Persistence.LOCAL : 
                    firebase.auth.Auth.Persistence.SESSION
                );

                // Sign in
                const userCredential = await auth.signInWithEmailAndPassword(email, password);
                const user = userCredential.user;

                console.log('✅ User authenticated:', user.uid);

                // Get user data from Firestore
                const userDoc = await db.collection('users').doc(user.uid).get();

                if (!userDoc.exists) {
                    await auth.signOut();
                    showAlert('User profile not found. Please run CEO setup first.', 'error');
                    loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login to Dashboard';
                    loginBtn.disabled = false;
                    return;
                }

                const userData = userDoc.data();
                console.log('📄 User role:', userData.role);

                // Check if user is admin or super_admin
                if (!['admin', 'super_admin'].includes(userData.role)) {
                    await auth.signOut();
                    showAlert('Access denied. Administrator privileges required.', 'error');
                    loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login to Dashboard';
                    loginBtn.disabled = false;
                    return;
                }

                // Check account status
                if (userData.status !== 'active') {
                    await auth.signOut();
                    showAlert('Account is not active. Please contact support.', 'error');
                    loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login to Dashboard';
                    loginBtn.disabled = false;
                    return;
                }

                // Get fresh token
                const token = await user.getIdToken();

                // Store user data
                const userInfo = {
                    uid: user.uid,
                    email: user.email,
                    fullName: userData.fullName || user.displayName || 'Admin',
                    role: userData.role,
                    permissions: userData.permissions || {}
                };

                if (rememberMe) {
                    localStorage.setItem('adminToken', token);
                    localStorage.setItem('adminUser', JSON.stringify(userInfo));
                } else {
                    sessionStorage.setItem('adminToken', token);
                    sessionStorage.setItem('adminUser', JSON.stringify(userInfo));
                }

                // Update last login
                await db.collection('users').doc(user.uid).update({
                    lastLogin: firebase.firestore.FieldValue.serverTimestamp(),
                    lastActive: firebase.firestore.FieldValue.serverTimestamp()
                });

                // Success message
                showAlert(`Welcome back, ${userInfo.fullName}!`, 'success');

                // Redirect based on role
                setTimeout(() => {
                    if (userData.role === 'super_admin') {
                        window.location.href = '/ceo-dashboard.html';
                    } else {
                        window.location.href = '/dashboard/';
                    }
                }, 1500);

            } catch (error) {
                console.error('❌ Login error:', error);
                
                let errorMessage = 'Login failed. Please try again.';
                
                if (error.code === 'auth/user-not-found') {
                    errorMessage = 'User not found. Please run CEO setup first.';
                } else if (error.code === 'auth/wrong-password') {
                    errorMessage = 'Invalid password.';
                } else if (error.code === 'auth/too-many-requests') {
                    errorMessage = 'Too many failed attempts. Try again later.';
                } else if (error.code === 'auth/network-request-failed') {
                    errorMessage = 'Network error. Check your connection.';
                } else {
                    errorMessage = error.message;
                }
                
                showAlert(errorMessage, 'error');
                loginBtn.innerHTML = '<i class="fas fa-sign-in-alt"></i> Login to Dashboard';
                loginBtn.disabled = false;
            }
        });

        // ============================================
        // CHECK EXISTING SESSION
        // ============================================
        auth.onAuthStateChanged(async (user) => {
            if (user) {
                console.log('👤 User already logged in:', user.email);
                
                try {
                    const userDoc = await db.collection('users').doc(user.uid).get();
                    
                    if (userDoc.exists) {
                        const userData = userDoc.data();
                        
                        if (userData.role === 'super_admin') {
                            window.location.href = '/ceo-dashboard.html';
                        } else if (['admin'].includes(userData.role)) {
                            window.location.href = '/dashboard/';
                        }
                    }
                } catch (error) {
                    console.error('Error checking session:', error);
                }
            }
        });

        // ============================================
        // CHECK SETUP STATUS
        // ============================================
        async function checkSetupStatus() {
            try {
                const settingsDoc = await db.collection('settings').doc('platform').get();
                
                if (!settingsDoc.exists) {
                    document.querySelector('.setup-link').style.display = 'block';
                } else {
                    // Hide setup link if platform is already set up
                    // But keep it visible in case CEO needs to run again
                }
            } catch (error) {
                console.error('Error checking setup:', error);
            }
        }

        // Run setup check
        checkSetupStatus();
    </script>
</body>
</html>
