<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | TAAGC Global</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="css/admin.css">
</head>
<body class="login-body">
    <div class="login-card">
        <div class="sidebar-logo" style="margin-bottom:30px;">
            <div class="logo-icon">A</div>
            <div class="logo-text"><span>TAAGC</span> ADMIN</div>
        </div>

        <span class="admin-badge">
            <i class="fas fa-shield-alt"></i> ADMINISTRATOR ACCESS
        </span>

        <h1 style="font-size:28px; margin-bottom:8px; color:#0a2540;">Admin Login</h1>
        <p style="color:#64748b; margin-bottom:24px;">Enter your administrator credentials</p>

        <div id="alertMessage" class="alert" style="display:none; padding:16px; border-radius:12px; margin-bottom:20px;"></div>

        <form id="adminLoginForm">
            <div class="form-group">
                <label><i class="fas fa-envelope" style="color:#c19a6b;"></i> Email</label>
                <input type="email" id="email" class="form-control" placeholder="admin@taagc.com" value="priahmz@gmail.com" required style="padding-left:16px;">
            </div>
            <div class="form-group">
                <label><i class="fas fa-lock" style="color:#c19a6b;"></i> Password</label>
                <input type="password" id="password" class="form-control" placeholder="••••••••" value="Admin/Taagc/001" required style="padding-left:16px;">
            </div>
            <button type="submit" class="btn" id="loginBtn" style="width:100%;">
                <i class="fas fa-shield-alt"></i> Login to Admin Panel
            </button>
        </form>
        
        <div style="margin-top:30px; text-align:center; font-size:14px; color:#64748b;">
            <i class="fas fa-cog"></i> First time? <a href="/setup-admin.html" style="color:#c19a6b; text-decoration:none; font-weight:600;">Create administrator account</a>
        </div>
    </div>

    <script type="module" src="js/admin-auth.js"></script>
</body>
</html>
