{
  "name": "taagc-admin",
  "version": 2,
  "alias": ["admin.taagc.website"],
  "regions": ["iad1"],
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/profile",
      "dest": "/profile.html"
    },
    {
      "src": "/users",
      "dest": "/users/index.html"
    },
    {
      "src": "/users/create",
      "dest": "/users/create.html"
    },
    {
      "src": "/users/edit",
      "dest": "/users/edit.html"
    },
    {
      "src": "/users/view",
      "dest": "/users/view.html"
    },
    {
      "src": "/admins",
      "dest": "/admins/index.html"
    },
    {
      "src": "/admins/create",
      "dest": "/admins/create.html"
    },
    {
      "src": "/staff",
      "dest": "/staff/index.html"
    },
    {
      "src": "/staff/schedule",
      "dest": "/staff/schedule.html"
    },
    {
      "src": "/staff/attendance",
      "dest": "/staff/attendance.html"
    },
    {
      "src": "/staff/leave",
      "dest": "/staff/leave.html"
    },
    {
      "src": "/staff/performance",
      "dest": "/staff/performance.html"
    },
    {
      "src": "/investments",
      "dest": "/investments/index.html"
    },
    {
      "src": "/investments/create",
      "dest": "/investments/create.html"
    },
    {
      "src": "/transactions",
      "dest": "/transactions/index.html"
    },
    {
      "src": "/transactions/deposits",
      "dest": "/transactions/deposits.html"
    },
    {
      "src": "/transactions/withdrawals",
      "dest": "/transactions/withdrawals.html"
    },
    {
      "src": "/banks",
      "dest": "/banks/index.html"
    },
    {
      "src": "/banks/accounts",
      "dest": "/banks/accounts.html"
    },
    {
      "src": "/banks/transactions",
      "dest": "/banks/transactions.html"
    },
    {
      "src": "/banks/reconciliation",
      "dest": "/banks/reconciliation.html"
    },
    {
      "src": "/agencies",
      "dest": "/agencies/index.html"
    },
    {
      "src": "/agencies/contracts",
      "dest": "/agencies/contracts.html"
    },
    {
      "src": "/agencies/commissions",
      "dest": "/agencies/commissions.html"
    },
    {
      "src": "/agencies/payments",
      "dest": "/agencies/payments.html"
    },
    {
      "src": "/events",
      "dest": "/events/index.html"
    },
    {
      "src": "/events/calendar",
      "dest": "/events/calendar.html"
    },
    {
      "src": "/events/registrations",
      "dest": "/events/registrations.html"
    },
    {
      "src": "/events/attendees",
      "dest": "/events/attendees.html"
    },
    {
      "src": "/events/feedback",
      "dest": "/events/feedback.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_FIREBASE_API_KEY": "AIzaSyCOcCDPqRSlAMJJBEeNchTA1qO9tl9Nldw",
    "NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN": "xtaagc.firebaseapp.com",
    "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "xtaagc",
    "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": "xtaagc.appspot.com",
    "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "256073982437",
    "NEXT_PUBLIC_FIREBASE_APP_ID": "1:256073982437:web:8da63bb7acc86c0ca98f0c",
    "NEXT_PUBLIC_API_URL": "https://api.taagc.website",
    "NODE_ENV": "production"
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "github": {
    "enabled": true,
    "silent": true
  }
}
