<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TAAGC GAMES - Play & Earn | Free Online Games</title>
    <meta name="description" content="Play 200+ free online games. Racing, Football, Multiplayer. Earn points, join tournaments, trade in marketplace. Fast loading, low data usage!">
    <meta name="keywords" content="free online games, racing games, football games, multiplayer games, play to earn, game points">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #667eea;
            --primary-dark: #5a67d8;
            --secondary: #764ba2;
            --secondary-dark: #6b46c1;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --info: #3b82f6;
            --dark: #1a1a1a;
            --light: #f3f4f6;
            --gray: #9ca3af;
            --white: #ffffff;
            --gradient: linear-gradient(135deg, var(--primary), var(--secondary));
            --gradient-hover: linear-gradient(135deg, var(--primary-dark), var(--secondary-dark));
        }

        body {
            background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
            color: #333;
            min-height: 100vh;
        }

        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 3px solid transparent;
            background-image: linear-gradient(white, white), var(--gradient);
            background-origin: border-box;
            background-clip: padding-box, border-box;
        }

        .nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 5%;
            max-width: 1400px;
            margin: 0 auto;
        }

        .logo {
            font-size: 2rem;
            font-weight: 800;
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .logo i {
            font-size: 2.2rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .referral-section {
            display: flex;
            align-items: center;
            gap: 1rem;
            background: #f8fafc;
            padding: 0.5rem;
            border-radius: 50px;
            border: 2px solid #e5e7eb;
        }

        .referral-code {
            background: var(--gradient);
            color: white;
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .referral-code:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102,126,234,0.3);
        }

        .referral-code i {
            font-size: 1rem;
        }

        .wallet-widget {
            background: var(--success);
            color: white;
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s;
            border: 2px solid transparent;
        }

        .wallet-widget:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
            background: #0d9488;
        }

        /* Category Navigation */
        .categories {
            background: white;
            padding: 1rem 5%;
            border-bottom: 1px solid #e5e7eb;
            position: sticky;
            top: 80px;
            z-index: 999;
        }

        .category-scroll {
            display: flex;
            gap: 2rem;
            overflow-x: auto;
            padding: 0.5rem 0;
            max-width: 1400px;
            margin: 0 auto;
            scrollbar-width: thin;
            scrollbar-color: var(--primary) #e5e7eb;
        }

        .category-scroll::-webkit-scrollbar {
            height: 5px;
        }

        .category-scroll::-webkit-scrollbar-track {
            background: #e5e7eb;
            border-radius: 10px;
        }

        .category-scroll::-webkit-scrollbar-thumb {
            background: var(--gradient);
            border-radius: 10px;
        }

        .category-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
            color: #666;
            text-decoration: none;
            font-size: 0.9rem;
            transition: all 0.3s;
            min-width: 80px;
            padding: 0.5rem;
            border-radius: 10px;
        }

        .category-item:hover {
            color: var(--primary);
            transform: translateY(-2px);
            background: #f8fafc;
        }

        .category-item.active {
            color: var(--primary);
            font-weight: 600;
            background: linear-gradient(135deg, #667eea10, #764ba210);
        }

        .category-icon {
            width: 50px;
            height: 50px;
            background: var(--gradient);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            transition: all 0.3s;
        }

        .category-item:hover .category-icon {
            transform: scale(1.1);
        }

        /* Main Content */
        .main-content {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 5%;
        }

        /* Hero Banner - Clickable */
        .hero-banner {
            background: var(--gradient);
            border-radius: 30px;
            padding: 3rem;
            color: white;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 20px 40px rgba(102,126,234,0.3);
        }

        .hero-banner:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 50px rgba(102,126,234,0.4);
        }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(45deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 2;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .hero-text h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero-text p {
            font-size: 1.2rem;
            opacity: 0.95;
            margin-bottom: 2rem;
        }

        .hero-stats {
            display: flex;
            gap: 2rem;
        }

        .hero-stat {
            text-align: center;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            padding: 1rem 2rem;
            border-radius: 15px;
            border: 1px solid rgba(255,255,255,0.3);
        }

        .hero-stat .number {
            font-size: 2rem;
            font-weight: 800;
            display: block;
        }

        .hero-badge {
            position: absolute;
            top: 2rem;
            right: 2rem;
            background: var(--warning);
            color: var(--dark);
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            font-weight: 700;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        /* Promo Banners Grid - All Clickable */
        .promo-banners {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .promo-banner {
            background: white;
            border-radius: 20px;
            padding: 2rem 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .promo-banner:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(102,126,234,0.2);
            border-color: var(--primary);
        }

        .promo-banner i {
            font-size: 3rem;
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1rem;
        }

        .promo-banner h3 {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
        }

        .promo-banner p {
            color: #666;
            font-size: 0.9rem;
        }

        .promo-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: var(--danger);
            color: white;
            padding: 0.2rem 0.5rem;
            border-radius: 5px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* Section Title */
        .section-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 2rem 0 1.5rem;
        }

        .section-title h2 {
            font-size: 2rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .section-title h2 span {
            background: var(--gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .view-all {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            background: #f8fafc;
        }

        .view-all:hover {
            background: var(--gradient);
            color: white;
            transform: translateX(5px);
        }

        .view-all:hover i {
            transform: translateX(3px);
        }

        /* Games Grid */
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .game-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            transition: all 0.3s;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            border: 2px solid transparent;
        }

        .game-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 30px rgba(102,126,234,0.15);
            border-color: var(--primary);
        }

        .game-thumbnail {
            aspect-ratio: 1/1;
            background: linear-gradient(135deg, #667eea20, #764ba220);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }

        .game-badge {
            position: absolute;
            top: 10px;
            right: 10px;
            background: var(--gradient);
            color: white;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .game-info {
            padding: 1rem;
        }

        .game-title {
            font-weight: 600;
            margin-bottom: 0.3rem;
            font-size: 1rem;
        }

        .game-meta {
            display: flex;
            justify-content: space-between;
            color: #666;
            font-size: 0.8rem;
        }

        .game-players {
            color: var(--primary);
            font-weight: 600;
        }

        /* Tournament Cards */
        .tournament-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .tournament-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .tournament-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(102,126,234,0.2);
            border-color: var(--primary);
        }

        .tournament-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .tournament-game {
            font-size: 2rem;
        }

        .tournament-status {
            background: var(--success);
            color: white;
            padding: 0.2rem 1rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .tournament-prize {
            font-size: 2rem;
            color: var(--warning);
            font-weight: 800;
            margin: 1rem 0;
        }

        .tournament-entry {
            display: inline-block;
            background: var(--gradient);
            color: white;
            padding: 0.3rem 1rem;
            border-radius: 10px;
            font-size: 0.9rem;
            margin-bottom: 1rem;
        }

        .tournament-progress {
            margin: 1rem 0;
        }

        .progress-bar {
            height: 8px;
            background: #e5e7eb;
            border-radius: 4px;
            overflow: hidden;
            margin: 0.5rem 0;
        }

        .progress-fill {
            height: 100%;
            background: var(--gradient);
            transition: width 0.3s;
        }

        .tournament-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid #e5e7eb;
        }

        /* Marketplace Preview */
        .marketplace-preview {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            margin: 2rem 0;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            cursor: pointer;
            transition: all 0.3s;
            border: 2px solid transparent;
        }

        .marketplace-preview:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(102,126,234,0.2);
            border-color: var(--primary);
        }

        .marketplace-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .marketplace-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            text-align: center;
        }

        .marketplace-stat .value {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary);
        }

        /* Wallet Preview */
        .wallet-preview {
            background: var(--gradient);
            border-radius: 20px;
            padding: 2rem;
            color: white;
            margin: 2rem 0;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 20px 40px rgba(102,126,234,0.3);
        }

        .wallet-preview:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 50px rgba(102,126,234,0.4);
        }

        .wallet-balance {
            font-size: 3rem;
            font-weight: 800;
            margin: 1rem 0;
        }

        .wallet-actions {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
        }

        .wallet-btn {
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            padding: 0.8rem 2rem;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            flex: 1;
        }

        .wallet-btn:hover {
            background: white;
            color: var(--primary);
            transform: translateY(-2px);
        }

        /* Footer */
        .footer {
            background: var(--dark);
            color: white;
            padding: 4rem 5% 2rem;
            margin-top: 4rem;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        .footer-section h3 {
            margin-bottom: 1.5rem;
            font-size: 1.2rem;
            position: relative;
            padding-bottom: 0.5rem;
        }

        .footer-section h3::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 50px;
            height: 2px;
            background: var(--gradient);
        }

        .footer-section ul {
            list-style: none;
        }

        .footer-section ul li {
            margin-bottom: 0.8rem;
        }

        .footer-section ul li a {
            color: #999;
            text-decoration: none;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .footer-section ul li a:hover {
            color: white;
            transform: translateX(5px);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 3rem;
            margin-top: 3rem;
            border-top: 1px solid #333;
            color: #999;
        }

        /* Game Modal */
        .game-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 2000;
            backdrop-filter: blur(5px);
        }

        .game-modal.active {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .game-modal-content {
            width: 90%;
            height: 90%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            position: relative;
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 20px;
            background: var(--danger);
            color: white;
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 2001;
            transition: all 0.3s;
        }

        .close-modal:hover {
            transform: rotate(90deg);
            background: #dc2626;
        }

        .game-frame {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Toast Notifications */
        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: var(--success);
            color: white;
            padding: 1rem 2rem;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            z-index: 3000;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .promo-banners {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .nav {
                flex-direction: column;
                gap: 1rem;
            }
            
            .hero-content {
                flex-direction: column;
                text-align: center;
            }
            
            .hero-stats {
                flex-direction: column;
                gap: 1rem;
            }
            
            .promo-banners {
                grid-template-columns: 1fr;
            }
            
            .games-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            
            .marketplace-stats {
                grid-template-columns: 1fr;
                gap: 1rem;
            }
            
            .wallet-actions {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Header with Referral System -->
    <div class="header">
        <div class="nav">
            <a href="/" class="logo">
                <i class="fas fa-gamepad"></i> TAAGC GAMES
            </a>
            
            <div class="referral-section">
                <div class="referral-code" onclick="copyReferral()">
                    <i class="fas fa-gift"></i>
                    <span id="referralCode">games.taagc.website/?ref=user123</span>
                    <i class="fas fa-copy"></i>
                </div>
                <span style="color: #666;">Earn 50 pts per referral</span>
            </div>
            
            <div class="wallet-widget" onclick="window.location.href='/wallet'">
                <i class="fas fa-wallet"></i>
                <span id="walletBalance">2,500</span> PTS
                <i class="fas fa-chevron-right"></i>
            </div>
        </div>
    </div>

    <!-- Category Navigation - All Clickable -->
    <div class="categories">
        <div class="category-scroll">
            <a href="/" class="category-item active">
                <div class="category-icon"><i class="fas fa-home"></i></div>
                <span>Home</span>
            </a>
            <a href="/online-games" class="category-item">
                <div class="category-icon"><i class="fas fa-globe"></i></div>
                <span>Online</span>
                <span style="font-size: 0.7rem; color: var(--success);">124 games</span>
            </a>
            <a href="/racing-games" class="category-item">
                <div class="category-icon"><i class="fas fa-car"></i></div>
                <span>Racing</span>
                <span style="font-size: 0.7rem; color: var(--success);">48 games</span>
            </a>
            <a href="/football-games" class="category-item">
                <div class="category-icon"><i class="fas fa-futbol"></i></div>
                <span>Football</span>
                <span style="font-size: 0.7rem; color: var(--success);">32 games</span>
            </a>
            <a href="/multiplayer-games" class="category-item">
                <div class="category-icon"><i class="fas fa-users"></i></div>
                <span>Multiplayer</span>
                <span style="font-size: 0.7rem; color: var(--success);">28 games</span>
            </a>
            <a href="/tournaments" class="category-item">
                <div class="category-icon"><i class="fas fa-trophy"></i></div>
                <span>Tournaments</span>
                <span style="font-size: 0.7rem; color: var(--warning);">12 live</span>
            </a>
            <a href="/rewards" class="category-item">
                <div class="category-icon"><i class="fas fa-gift"></i></div>
                <span>Rewards</span>
                <span style="font-size: 0.7rem; color: var(--warning);">Claim</span>
            </a>
            <a href="/wallet" class="category-item">
                <div class="category-icon"><i class="fas fa-wallet"></i></div>
                <span>Wallet</span>
                <span style="font-size: 0.7rem; color: var(--primary);">2.5k pts</span>
            </a>
            <a href="/marketplace" class="category-item">
                <div class="category-icon"><i class="fas fa-store"></i></div>
                <span>Market</span>
                <span style="font-size: 0.7rem; color: var(--primary);">42 trades</span>
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Hero Banner - Clickable -->
        <div class="hero-banner" onclick="window.location.href='/tournaments'">
            <div class="hero-content">
                <div class="hero-text">
                    <h1>🏆 Mega Tournament</h1>
                    <p>50,000 PTS Prize Pool • 500 PTS Entry • 89/100 Players</p>
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <span class="number">50K</span>
                            <span>Prize Pool</span>
