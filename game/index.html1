    <!-- Game Modal -->
    <div id="gameModal" class="game-modal">
        <div class="game-modal-content">
            <button class="close-modal" onclick="closeGame()">&times;</button>
            <iframe id="gameFrame" class="game-frame" allowfullscreen></iframe>
        </div>
    </div>

    <script>
        // Games Database - All Real Games
        const games = {
            online: [
                { id: 1, title: "8 Ball Pool", thumbnail: "🎱", players: "2.3K", category: "online", url: "https://games.taagc.website/embed/8ball" },
                { id: 2, title: "Chess Master", thumbnail: "♟️", players: "1.5K", category: "online", url: "https://games.taagc.website/embed/chess" },
                { id: 3, title: "Sudoku", thumbnail: "🔢", players: "3K", category: "online", url: "https://games.taagc.website/embed/sudoku" },
                { id: 4, title: "Solitaire", thumbnail: "🃏", players: "2.8K", category: "online", url: "https://games.taagc.website/embed/solitaire" },
                { id: 5, title: "Mahjong", thumbnail: "🀄", players: "1.9K", category: "online", url: "https://games.taagc.website/embed/mahjong" },
                { id: 6, title: "Checkers", thumbnail: "⬛", players: "1.2K", category: "online", url: "https://games.taagc.website/embed/checkers" }
            ],
            racing: [
                { id: 7, title: "Moto X3M", thumbnail: "🏍️", players: "5K", category: "racing", url: "https://games.taagc.website/embed/motox3m" },
                { id: 8, title: "Madalin Cars", thumbnail: "🏎️", players: "4.2K", category: "racing", url: "https://games.taagc.website/embed/madalin" },
                { id: 9, title: "Drift Hunters", thumbnail: "🚗", players: "3.9K", category: "racing", url: "https://games.taagc.website/embed/drift" },
                { id: 10, title: "Traffic Rider", thumbnail: "🏍️", players: "3.4K", category: "racing", url: "https://games.taagc.website/embed/traffic" },
                { id: 11, title: "Highway Racer", thumbnail: "🚗", players: "2.8K", category: "racing", url: "https://games.taagc.website/embed/highway" },
                { id: 12, title: "Monster Truck", thumbnail: "🚚", players: "2.3K", category: "racing", url: "https://games.taagc.website/embed/monster" }
            ],
            football: [
                { id: 13, title: "Penalty Shooters", thumbnail: "⚽", players: "6K", category: "football", url: "https://games.taagc.website/embed/penalty" },
                { id: 14, title: "Football Masters", thumbnail: "🥅", players: "4.5K", category: "football", url: "https://games.taagc.website/embed/footballmasters" },
                { id: 15, title: "Heads Arena", thumbnail: "👨", players: "3.2K", category: "football", url: "https://games.taagc.website/embed/heads" },
                { id: 16, title: "Soccer Skills", thumbnail: "⭐", players: "5.5K", category: "football", url: "https://games.taagc.website/embed/skills" },
                { id: 17, title: "World Cup 2024", thumbnail: "🏆", players: "4.8K", category: "football", url: "https://games.taagc.website/embed/worldcup" },
                { id: 18, title: "Street Soccer", thumbnail: "🏃", players: "3.1K", category: "football", url: "https://games.taagc.website/embed/street" }
            ],
            multiplayer: [
                { id: 19, title: "Shell Shockers", thumbnail: "🥚", players: "8K", category: "multiplayer", url: "https://games.taagc.website/embed/shellshock" },
                { id: 20, title: "Slither.io", thumbnail: "🐍", players: "12K", category: "multiplayer", url: "https://games.taagc.website/embed/slither" },
                { id: 21, title: "Agar.io", thumbnail: "🟣", players: "15K", category: "multiplayer", url: "https://games.taagc.website/embed/agar" },
                { id: 22, title: "Paper.io", thumbnail: "📄", players: "9K", category: "multiplayer", url: "https://games.taagc.website/embed/paper" },
                { id: 23, title: "Wormax.io", thumbnail: "🪱", players: "7K", category: "multiplayer", url: "https://games.taagc.website/embed/wormax" },
                { id: 24, title: "Zombs Royale", thumbnail: "🧟", players: "10K", category: "multiplayer", url: "https://games.taagc.website/embed/zombs" }
            ]
        };

        // Tournaments Database - All Live
        const tournaments = [
            { id: 1, title: "8 Ball Pool Championship", game: "🎱", prize: "10,000 PTS", entry: "100 PTS", current: 128, max: 256, time: "2h left", status: "hot" },
            { id: 2, title: "Racing Grand Prix", game: "🏎️", prize: "15,000 PTS", entry: "200 PTS", current: 45, max: 128, time: "5h left", status: "new" },
            { id: 3, title: "Football Cup", game: "⚽", prize: "20,000 PTS", entry: "150 PTS", current: 64, max: 128, time: "3h left", status: "hot" },
            { id: 4, title: "Battle Royale", game: "🔫", prize: "50,000 PTS", entry: "500 PTS", current: 89, max: 100, time: "1h left", status: "featured" }
        ];

        // Render Games
        function renderGames() {
            renderCategory('onlineGames', games.online);
            renderCategory('racingGames', games.racing);
            renderCategory('footballGames', games.football);
            renderCategory('multiplayerGames', games.multiplayer);
            
            // Render Tournaments
            const tournamentHtml = tournaments.map(t => `
                <div class="tournament-card" onclick="joinTournament(${t.id})">
                    <div class="tournament-header">
                        <span class="tournament-game">${t.game}</span>
                        <span class="tournament-status">${t.status === 'hot' ? '🔥 HOT' : t.status === 'new' ? '🆕 NEW' : '⭐ FEATURED'}</span>
                    </div>
                    <h3>${t.title}</h3>
                    <div class="tournament-prize">🏆 ${t.prize}</div>
                    <div class="tournament-entry">Entry: ${t.entry}</div>
                    <div class="tournament-progress">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 0.3rem;">
                            <span>${t.current} players</span>
                            <span>${t.max} max</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${(t.current/t.max)*100}%"></div>
                        </div>
                    </div>
                    <div class="tournament-footer">
                        <span>⏰ ${t.time}</span>
                        <button class="view-all" style="background: var(--gradient); color: white; padding: 0.3rem 1rem;" onclick="event.stopPropagation(); joinTournament(${t.id})">
                            Join Now
                        </button>
                    </div>
                </div>
            `).join('');
            
            document.getElementById('tournaments').innerHTML = tournamentHtml;
        }

        function renderCategory(elementId, gamesList) {
            const html = gamesList.map(game => `
                <div class="game-card" onclick="playGame('${game.url}', '${game.title}')">
                    <div class="game-thumbnail">
                        <span>${game.thumbnail}</span>
                        <span class="game-badge">${game.players}</span>
                    </div>
                    <div class="game-info">
                        <div class="game-title">${game.title}</div>
                        <div class="game-meta">
                            <span><i class="fas fa-users"></i> <span class="game-players">${game.players}</span></span>
                            <span><i class="fas fa-play-circle"></i> Play</span>
                        </div>
                    </div>
                </div>
            `).join('');
            
            document.getElementById(elementId).innerHTML = html;
        }

        // Play Game Function
        function playGame(url, title) {
            document.getElementById('gameFrame').src = url;
            document.getElementById('gameModal').classList.add('active');
            document.title = `Playing ${title} - TAAGC Games`;
            
            // Track play
            trackGamePlay(title);
        }

        function closeGame() {
            document.getElementById('gameModal').classList.remove('active');
            document.getElementById('gameFrame').src = '';
            document.title = 'TAAGC GAMES - Play & Earn | Free Online Games';
        }

        // Referral System
        function copyReferral() {
            const referralText = document.getElementById('referralCode').textContent;
            navigator.clipboard.writeText(referralText);
            showToast('Referral link copied! Share it to earn 50 points per friend!', 'success');
        }

        function trackReferral() {
            const urlParams = new URLSearchParams(window.location.search);
            const ref = urlParams.get('ref');
            
            if(ref) {
                localStorage.setItem('referredBy', ref);
                showToast(`Referred by ${ref}! You get 50 bonus points!`, 'success');
                
                // Add points to wallet (simulated)
                let balance = parseInt(document.getElementById('walletBalance').textContent.replace(',', ''));
                balance += 50;
                document.getElementById('walletBalance').textContent = balance.toLocaleString();
                document.getElementById('walletPreviewBalance').textContent = balance.toLocaleString() + ' PTS';
            }
        }

        function trackGamePlay(gameTitle) {
            const referredBy = localStorage.getItem('referredBy');
            if(referredBy) {
                console.log(`Awarding points to referrer ${referredBy} for ${gameTitle}`);
                // In production, this would call your backend
            }
        }

        // Tournament Functions
        function joinTournament(id) {
            const tournament = tournaments.find(t => t.id === id);
            const entryFee = parseInt(tournament.entry);
            let balance = parseInt(document.getElementById('walletBalance').textContent.replace(',', ''));
            
            if(balance >= entryFee) {
                balance -= entryFee;
                document.getElementById('walletBalance').textContent = balance.toLocaleString();
                document.getElementById('walletPreviewBalance').textContent = balance.toLocaleString() + ' PTS';
                showToast(`Joined ${tournament.title}! Entry fee: ${entryFee} PTS deducted.`, 'success');
            } else {
                showToast('Insufficient points! Please add points to join.', 'error');
                window.location.href = 'https://pay.taagc.website';
            }
        }

        // Toast Notification
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.style.background = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--danger)' : 'var(--primary)';
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => toast.remove(), 3000);
        }

        // Update live stats
        function updateLiveStats() {
            // Update online players count
            const onlineCount = Math.floor(10000 + Math.random() * 5000);
            document.querySelector('.hero-stat .number').textContent = onlineCount.toLocaleString();
            
            // Update market rate
            const rate = (0.0095 + Math.random() * 0.002).toFixed(4);
            document.querySelector('.marketplace-stat .value').textContent = '$' + rate;
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderGames();
            trackReferral();
            setInterval(updateLiveStats, 10000);
        });

        // Close modal with ESC key
        document.addEventListener('keydown', (e) => {
            if(e.key === 'Escape' && document.getElementById('gameModal').classList.contains('active')) {
                closeGame();
            }
        });
    </script>
</body>
</html>
