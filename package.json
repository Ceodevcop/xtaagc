{
  "name": "taagc-platform",
  "version": "3.0.0",
  "description": "TAAGC Global - Complete Investment Platform",
  "main": "api/index.js",
  "author": "TAAGC Global",
  "license": "MIT",
  "private": false,
  "keywords": [
    "investment",
    "finance",
    "trading",
    "blockchain",
    "crypto",
    "portfolio",
    "firebase",
    "vercel",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/taagc/platform.git"
  },
  "bugs": {
    "url": "https://github.com/taagc/platform/issues"
  },
  "homepage": "https://taagc.website",
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "start": "node api/index.js",
    "build": "echo 'Building for production...'",
    "deploy": "vercel --prod",
    "deploy:staging": "vercel",
    "logs": "vercel logs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,css,md}\"",
    "backup": "node scripts/backup.js",
    "seed": "node scripts/seed.js",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",
    "prepare": "husky install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase": "^10.8.0",
    "firebase-admin": "^11.11.1",
    "firebase-functions": "^4.5.0",
    "firebase-tools": "^13.0.0",
    "@firebase/app": "^0.9.25",
    "@firebase/auth": "^1.5.1",
    "@firebase/firestore": "^4.4.1",
    "@firebase/storage": "^0.11.2",
    "@firebase/analytics": "^0.10.0",
    "@firebase/messaging": "^0.10.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "express-session": "^1.18.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "nanoid": "^5.0.4",
    "axios": "^1.6.5",
    "node-fetch": "^2.7.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "nodemailer": "^6.9.7",
    "nodemailer-sendgrid": "^1.0.3",
    "twilio": "^4.19.3",
    "stripe": "^14.8.0",
    "paypal-rest-sdk": "^1.8.1",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "notifications-node-client": "^7.0.4",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "web-push": "^3.6.0",
    "bull": "^4.11.5",
    "bull-board": "^5.10.3",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "mongoose": "^8.1.0",
    "pg": "^8.11.3",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.1",
    "prisma": "^5.7.0",
    "@prisma/client": "^5.7.0",
    "typeorm": "^0.3.17",
    "reflect-metadata": "^0.2.1",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "vercel": "^32.5.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.3",
    "cross-env": "^7.0.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "dotenv-cli": "^7.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "api/**/*.js",
      "!api/index.js"
    ]
  },
  "eslintConfig": {
    "extends": "airbnb-base",
    "env": {
      "node": true,
      "jest": true
    },
    "rules": {
      "no-console": "off",
      "import/no-unresolved": "off",
      "import/extensions": "off",
      "consistent-return": "off",
      "no-underscore-dangle": "off",
      "no-param-reassign": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100
  }
}
