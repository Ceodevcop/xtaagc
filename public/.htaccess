# .htaccess for TAAGC Global
# Version: 2.0.0

# --------------------------------------------
# Enable rewrite engine
# --------------------------------------------
RewriteEngine On
RewriteBase /

# --------------------------------------------
# Force HTTPS
# --------------------------------------------
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# --------------------------------------------
# Remove www
# --------------------------------------------
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# --------------------------------------------
# Custom error pages
# --------------------------------------------
ErrorDocument 404 /404
ErrorDocument 403 /404
ErrorDocument 500 /500
ErrorDocument 502 /500
ErrorDocument 503 /maintenance

# --------------------------------------------
# Redirects for clean URLs
# --------------------------------------------
RewriteRule ^about/?$ /public/about.html [L]
RewriteRule ^contact/?$ /public/contact.html [L]
RewriteRule ^faq/?$ /public/faq.html [L]
RewriteRule ^login/?$ /public/login.html [L]
RewriteRule ^register/?$ /public/register.html [L]
RewriteRule ^dashboard/?$ /public/dashboard.html [L]
RewriteRule ^profile/?$ /public/profile.html [L]
RewriteRule ^settings/?$ /public/settings.html [L]
RewriteRule ^investors/?$ /public/investors.html [L]
RewriteRule ^education/?$ /public/education.html [L]
RewriteRule ^calculator/?$ /public/calculator.html [L]
RewriteRule ^projects/?$ /public/projects.html [L]
RewriteRule ^portfolio/?$ /public/portfolio.html [L]
RewriteRule ^admin/?$ /public/admin.html [L]
RewriteRule ^terms/?$ /public/terms.html [L]
RewriteRule ^privacy/?$ /public/privacy.html [L]
RewriteRule ^404/?$ /public/404.html [L]
RewriteRule ^500/?$ /public/500.html [L]
RewriteRule ^maintenance/?$ /public/maintenance.html [L]
RewriteRule ^coming-soon/?$ /public/coming-soon.html [L]
RewriteRule ^search/?$ /public/search.html [L]

# --------------------------------------------
# API routes - proxy to Vercel/Node
# --------------------------------------------
RewriteRule ^api/(.*)$ http://localhost:3000/api/$1 [P,L]

# --------------------------------------------
# Security headers
# --------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https:;"
</IfModule>

# --------------------------------------------
# Cache control
# --------------------------------------------
<FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf)$">
    Header set Cache-Control "max-age=2592000, public"
</FilesMatch>

<FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=7200, must-revalidate"
</FilesMatch>

# --------------------------------------------
# Compression
# --------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>

# --------------------------------------------
# Block access to sensitive files
# --------------------------------------------
<FilesMatch "\.(env|git|htaccess|htpasswd|ini|log|sh|sql|bak|config)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# --------------------------------------------
# Directory listing
# --------------------------------------------
Options -Indexes

# --------------------------------------------
# Character set
# --------------------------------------------
AddDefaultCharset UTF-8
