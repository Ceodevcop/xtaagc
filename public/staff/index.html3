    <script>
        // ============================================
        // IMAGE AUTO-RESIZE AND OPTIMIZATION
        // ============================================
        function updateImageSize(img) {
            const container = img.closest('.img-container');
            if (!container) return;
            
            const badge = container.querySelector('.optimization-badge span.img-size');
            if (!badge) return;
            
            const width = img.naturalWidth;
            const height = img.naturalHeight;
            const containerHeight = container.offsetHeight;
            
            if (width && height) {
                badge.textContent = `${width}×${height} → ${containerHeight}px`;
            } else {
                badge.textContent = 'Optimized';
            }
        }

        // Auto-update all images on load
        window.addEventListener('load', () => {
            document.querySelectorAll('.img-container img').forEach(img => {
                updateImageSize(img);
            });
        });

        // Update on window resize
        window.addEventListener('resize', () => {
            document.querySelectorAll('.img-container img').forEach(img => {
                updateImageSize(img);
            });
        });

        // ============================================
        // MOBILE MENU TOGGLE
        // ============================================
        window.toggleMenu = function() {
            const navLinks = document.getElementById('navLinks');
            navLinks.classList.toggle('active');
        };

        // ============================================
        // ADMIN UPLOAD SECTION (visible with ?admin=true)
        // ============================================
        (function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('admin')) {
                document.getElementById('uploadSection').classList.add('visible');
            }
        })();

        // ============================================
        // IMAGE UPLOAD HANDLER (SIMULATED)
        // ============================================
        window.handleImageUpload = function(input) {
            const files = input.files;
            if (files.length === 0) return;
            
            const progress = document.getElementById('uploadProgress');
            const progressBar = document.getElementById('progressBar');
            
            progress.style.display = 'block';
            progressBar.style.width = '0%';
            
            let width = 0;
            const interval = setInterval(() => {
                width += 10;
                progressBar.style.width = width + '%';
                
                if (width >= 100) {
                    clearInterval(interval);
                    setTimeout(() => {
                        progress.style.display = 'none';
                        alert('Images uploaded and optimized! Page will refresh.');
                        location.reload();
                    }, 500);
                }
            }, 200);
        };

        // ============================================
        // CLOSE MOBILE MENU WHEN CLICKING LINK
        // ============================================
        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', () => {
                document.getElementById('navLinks').classList.remove('active');
            });
        });
    </script>
