            },
            { 
                rank: 19, 
                name: "Fatima Bello", 
                role: "Sr Associate, Procurement", 
                description: "CIPS certified. Manages procurement for 15 countries.",
                category: "support", 
                icon: "user", 
                initials: "FB",
                email: "f.bello@taagc.com"
            },
            { 
                rank: 20, 
                name: "Emmanuel Adebayo", 
                role: "Associate, Logistics", 
                description: "Supply chain coordinator for West African operations.",
                category: "support", 
                icon: "user", 
                initials: "EA",
                email: "e.adebayo@taagc.com"
            },
            { 
                rank: 21, 
                name: "Amina Yusuf", 
                role: "Jr Associate, Marketing", 
                description: "Digital marketing specialist. Manages social media and content strategy.",
                category: "support", 
                icon: "user", 
                initials: "AY",
                email: "a.yusuf@taagc.com"
            },
            { 
                rank: 22, 
                name: "Open Position", 
                role: "Entry Level", 
                description: "2 positions available in operations and support. Great opportunity for growth.",
                category: "support", 
                icon: "user", 
                initials: "H", 
                hiring: true,
                email: "careers@taagc.com"
            }
        ];

        // ============================================
        // GLOBAL VARIABLES
        // ============================================
        let currentFilter = 'all';
        let currentView = 'grid';
        let currentPage = 1;
        const itemsPerPage = 12;
        let filteredStaff = [...staffData];

        // ============================================
        // INITIALIZE PAGE
        // ============================================
        document.addEventListener('DOMContentLoaded', () => {
            updateStats();
            renderStaff();
            initializeEventListeners();
        });

        // ============================================
        // UPDATE STATISTICS
        // ============================================
        function updateStats() {
            const executive = staffData.filter(s => s.category === 'executive' && !s.hiring).length;
            const operations = staffData.filter(s => s.category === 'operations' && !s.hiring).length;
            const support = staffData.filter(s => s.category === 'support' && !s.hiring).length;
            const total = executive + operations + support;

            document.getElementById('totalStaff').textContent = total;
            document.getElementById('executiveCount').textContent = executive;
            document.getElementById('operationsCount').textContent = operations;
            document.getElementById('supportCount').textContent = support;
        }

        // ============================================
        // RENDER STAFF
        // ============================================
        function renderStaff() {
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageItems = filteredStaff.slice(0, end);
            
            renderGridView(pageItems);
            renderListView(pageItems);
            
            // Show/hide load more button
            const loadMoreBtn = document.getElementById('loadMoreBtn');
            if (filteredStaff.length > end) {
                loadMoreBtn.style.display = 'inline-block';
            } else {
                loadMoreBtn.style.display = 'none';
            }
            
            // Hide loading state
            document.getElementById('loadingState').style.display = 'none';
            
            // Show/hide no results
            if (filteredStaff.length === 0) {
                document.getElementById('noResults').style.display = 'block';
                document.getElementById('staffGrid').style.display = 'none';
                document.getElementById('staffList').style.display = 'none';
            } else {
                document.getElementById('noResults').style.display = 'none';
                if (currentView === 'grid') {
                    document.getElementById('staffGrid').style.display = 'grid';
                    document.getElementById('staffList').style.display = 'none';
                } else {
                    document.getElementById('staffGrid').style.display = 'none';
                    document.getElementById('staffList').style.display = 'block';
                }
            }
        }

        // ============================================
        // RENDER GRID VIEW
        // ============================================
        function renderGridView(staff) {
            const grid = document.getElementById('staffGrid');
            let html = '';

            staff.forEach(member => {
                const hiringText = member.hiring ? ' • Hiring' : '';
                const rankIcon = getRankIcon(member.icon);
                
                html += `
                    <div class="staff-card" data-category="${member.category}" data-rank="${member.rank}" data-name="${member.name}" data-role="${member.role}">
                        <div class="staff-image-container">
                            <img src="staff/${member.initials}.png" 
                                 alt="${member.name}" 
                                 class="staff-image"
                                 onerror="this.src='https://ui-avatars.com/api/?name=${member.initials}&background=c19a6b&color=fff&size=200'">
                            <span class="staff-rank-badge">Rank ${String(member.rank).padStart(2, '0')}</span>
                            <span class="staff-category-badge"><i class="fas fa-${member.icon}"></i> ${member.category}</span>
                        </div>
                        <div class="staff-info">
                            <h3 class="staff-name">${member.name} ${member.hiring ? '<span class="hiring-badge">Hiring</span>' : ''}</h3>
                            <div class="staff-role">${member.role}</div>
                            <p class="staff-bio">${member.description}</p>
                            
                            <div class="staff-details">
                                <span class="staff-detail-item"><i class="fas fa-envelope"></i> ${member.email}</span>
                                ${member.phone ? `<span class="staff-detail-item"><i class="fas fa-phone"></i> ${member.phone}</span>` : ''}
                            </div>
                            
                            <div class="staff-social">
                                ${member.linkedin ? `<a href="${member.linkedin}" class="social-link"><i class="fab fa-linkedin-in"></i></a>` : ''}
                                ${member.twitter ? `<a href="${member.twitter}" class="social-link"><i class="fab fa-twitter"></i></a>` : ''}
                                <a href="#" class="social-link" onclick="openContactModal('${member.rank}')"><i class="fas fa-envelope"></i></a>
                            </div>
                            
                            <div class="staff-actions">
                                <button class="btn-view-profile" onclick="viewProfile(${member.rank})">
                                    <i class="fas fa-user"></i> View Profile
                                </button>
                                <button class="btn-contact" onclick="openContactModal('${member.rank}')">
                                    <i class="fas fa-comment"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });

            grid.innerHTML = html;
        }

        // ============================================
        // RENDER LIST VIEW
        // ============================================
        function renderListView(staff) {
            const list = document.getElementById('staffList');
            let html = '';

            staff.forEach(member => {
                html += `
                    <div class="list-item" data-category="${member.category}" data-rank="${member.rank}">
                        <img src="staff/${member.initials}.png" 
                             alt="${member.name}" 
                             class="list-image"
                             onerror="this.src='https://ui-avatars.com/api/?name=${member.initials}&background=c19a6b&color=fff&size=100'">
                        <div class="list-info">
                            <h3>${member.name}</h3>
                            <p>${member.description.substring(0, 100)}...</p>
                        </div>
                        <div class="list-role">${member.role}</div>
                        <div class="list-rank">Rank ${String(member.rank).padStart(2, '0')}</div>
                        <div class="list-actions">
                            <button class="btn-view-profile" onclick="viewProfile(${member.rank})">View</button>
                            <button class="btn-contact" onclick="openContactModal('${member.rank}')">
                                <i class="fas fa-envelope"></i>
                            </button>
                        </div>
                    </div>
                `;
            });

            list.innerHTML = html;
        }

        // ============================================
        // HELPER FUNCTIONS
        // ============================================
        function getRankIcon(icon) {
            const icons = {
                crown: 'fa-crown',
                star: 'fa-star',
                medal: 'fa-medal',
                shield: 'fa-shield',
                user: 'fa-user'
            };
            return icons[icon] || 'fa-user';
        }

        // ============================================
        // FILTER FUNCTIONS
        // ============================================
        function initializeEventListeners() {
            // Filter buttons
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                    e.target.classList.add('active');
                    
                    currentFilter = e.target.dataset.filter;
                    currentPage = 1;
                    
                    filterStaff();
                });
            });

            // Search input
            document.getElementById('searchInput').addEventListener('input', debounce(() => {
                filterStaff();
            }, 300));

            // Sort select
            document.getElementById('sortSelect').addEventListener('change', () => {
                sortStaff();
            });

            // View toggle
            document.getElementById('viewToggle').addEventListener('click', () => {
                const icon = document.querySelector('#viewToggle i');
                if (currentView === 'grid') {
                    currentView = 'list';
                    icon.className = 'fas fa-th-list';
                } else {
                    currentView = 'grid';
                    icon.className = 'fas fa-th-large';
                }
                renderStaff();
            });

            // Load more button
            document.getElementById('loadMoreBtn').addEventListener('click', () => {
                currentPage++;
                renderStaff();
            });
        }

        function filterStaff() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            filteredStaff = staffData.filter(member => {
                // Category filter
                if (currentFilter !== 'all' && member.category !== currentFilter && !(currentFilter === 'hiring' && member.hiring)) {
                    return false;
                }
                
                // Hiring filter
                if (currentFilter === 'hiring' && !member.hiring) {
                    return false;
                }
                
                // Search filter
                if (searchTerm) {
                    return member.name.toLowerCase().includes(searchTerm) || 
                           member.role.toLowerCase().includes(searchTerm) ||
                           member.description.toLowerCase().includes(searchTerm);
                }
                
                return true;
            });
            
            currentPage = 1;
            renderStaff();
        }

        function sortStaff() {
            const sortBy = document.getElementById('sortSelect').value;
            
            filteredStaff.sort((a, b) => {
                if (sortBy === 'rank') return a.rank - b.rank;
                if (sortBy === 'name') return a.name.localeCompare(b.name);
                if (sortBy === 'role') return a.role.localeCompare(b.role);
            });
            
            renderStaff();
        }

        // ============================================
        // MODAL FUNCTIONS
        // ============================================
        window.viewProfile = function(rank) {
            const member = staffData.find(m => m.rank === rank);
            if (!member) return;
            
            const modal = document.getElementById('profileModal');
            const content = document.getElementById('modalContent');
            
            content.innerHTML = `
                <div class="profile-header">
                    <img src="/assets/images/staff/${member.initials}.jpg" 
                         alt="${member.name}"
                         onerror="this.src='https://ui-avatars.com/api/?name=${member.initials}&background=c19a6b&color=fff&size=200'">
                    <div>
                        <h2>${member.name}</h2>
                        <p style="color: var(--accent); font-weight: 600;">${member.role}</p>
                        <p>Rank ${String(member.rank).padStart(2, '0')} • ${member.category}</p>
                    </div>
                </div>
                
                <div class="profile-detail">
                    <strong>Biography</strong>
                    <p>${member.description}</p>
                </div>
                
                <div class="profile-detail">
                    <strong>Contact</strong>
                    <p><i class="fas fa-envelope" style="color: var(--accent);"></i> ${member.email}</p>
                    ${member.phone ? `<p><i class="fas fa-phone" style="color: var(--accent);"></i> ${member.phone}</p>` : ''}
                </div>
                
                ${member.expertise ? `
                <div class="profile-detail">
                    <strong>Areas of Expertise</strong>
                    <p>${member.expertise.join(' • ')}</p>
                </div>
                ` : ''}
                
                ${member.education ? `
                <div class="profile-detail">
                    <strong>Education</strong>
                    <p>${member.education}</p>
                </div>
                ` : ''}
            `;
            
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        };

        window.closeModal = function() {
            document.getElementById('profileModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        };

        window.openContactModal = function(rank) {
            const member = staffData.find(m => m.rank == rank);
            if (!member) return;
            
            document.getElementById('contactMemberId').value = rank;
            document.getElementById('contactModal').classList.add('active');
        };

        window.closeContactModal = function() {
            document.getElementById('contactModal').classList.remove('active');
        };

        // ============================================
        // CONTACT FORM
        // ============================================
        window.sendContact = async function(e) {
            e.preventDefault();
            
            const rank = document.getElementById('contactMemberId').value;
            const member = staffData.find(m => m.rank == rank);
            const name = document.getElementById('contactName').value;
            const email = document.getElementById('contactEmail').value;
            const message = document.getElementById('contactMessage').value;
            
            // Show loading state
            const btn = e.target.querySelector('button');
            const originalText = btn.textContent;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sending...';
            btn.disabled = true;
            
            // Simulate sending (replace with actual API call)
            setTimeout(() => {
                showToast(`Message sent to ${member.name}!`, 'success');
                closeContactModal();
                e.target.reset();
                btn.innerHTML = originalText;
                btn.disabled = false;
            }, 1500);
        };

        // ============================================
        // TOAST NOTIFICATIONS
        // ============================================
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `
                <i class="fas fa-${type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle'}"></i>
                <span>${message}</span>
            `;
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 3000);
        }

        // ============================================
        // DEBOUNCE FUNCTION
        // ============================================
        function debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }

        // ============================================
        // EXPORT FUNCTIONS
        // ============================================
        window.exportStaff = function() {
            const csv = staffData.map(member => {
                return `${member.rank},${member.name},${member.role},${member.category},${member.email}`;
            }).join('\n');
            
            const blob = new Blob([`Rank,Name,Role,Category,Email\n${csv}`], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `taagc-staff-${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
            URL.revokeObjectURL(url);
            
            showToast('Staff list exported!', 'success');
        };

        // Close modals when clicking outside
        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('active');
                document.body.style.overflow = 'auto';
            }
        };
    </script>
</body>
</html>
