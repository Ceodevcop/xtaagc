{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "admin/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    // Public pages
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/register", "dest": "/public/register.html" },
    { "src": "/complete-profile", "dest": "/public/complete-profile.html" },
    { "src": "/events", "dest": "/public/events.html" },
    { "src": "/404", "dest": "/public/404.html" },
    
    // Admin
    { "src": "/admin/dashboard", "dest": "/admin/dashboard.html" },
    { "src": "/admin/setup", "dest": "/admin/setup.html" },
    
    // API
    { "src": "/api/(.*)", "dest": "/api/$1" },
    
    // Static assets
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    
    // Fallback
    { "src": "/(.*)", "dest": "/public/404.html" }
  ]
}
