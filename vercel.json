{
  "version": 2,

  "routes": [
    { "handle": "filesystem" },

    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/index$", "dest": "/public/index.html" },
    { "src": "^/home$", "dest": "/public/index.html" },

    { "src": "^/login$", "dest": "/public/login.html" },
    { "src": "^/register$", "dest": "/public/register.html" },
    { "src": "^/complete-profile$", "dest": "/public/complete-profile.html" },
    { "src": "^/events$", "dest": "/public/events.html" },

    { "src": "^/admin/dashboard$", "dest": "/admin/dashboard.html" },
    { "src": "^/admin/setup$", "dest": "/admin/setup.html" },

    { "src": "^/xtaagc/admin-login$", "dest": "/xtaagc/admin-login.html" },

    { "src": "^/api/(.*)", "dest": "/api/$1" },

    { "src": "/(.*)", "dest": "/public/404.html" }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
