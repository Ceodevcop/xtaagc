{
  "version": 2,
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "^/$", "dest": "/public/index.html" },
    { "src": "^/login$", "dest": "/public/login.html" },
    { "src": "^/register$", "dest": "/public/register.html" },
    { "src": "^/complete-profile$", "dest": "/public/complete-profile.html" },
    { "src": "^/events$", "dest": "/public/events.html" },

    { "src": "^/api/(.*)", "dest": "/api/$1" },

    { "src": "^/css/(.*)", "dest": "/css/$1" },
    { "src": "^/js/(.*)", "dest": "/js/$1" },
    { "src": "^/assets/(.*)", "dest": "/assets/$1" },

    { "src": "/(.*)", "dest": "/public/404.html" }
  ]
}
