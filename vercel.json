{
  "version": 2,

  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },

    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/register", "destination": "/public/register.html" },
    { "source": "/events", "destination": "/public/events.html" },
    { "source": "/complete-profile", "destination": "/public/complete-profile.html" },

    { "source": "/profile/client", "destination": "/public/profile/client/index.html" },
    { "source": "/profile/investors", "destination": "/public/profile/investors/index.html" },

    { "source": "/staff", "destination": "/public/staff/index.html" },

    { "source": "/admin/login", "destination": "/public/xtaagc/admin-login/index.html" },
    { "source": "/admin/setup", "destination": "/public/setup-admin.html" },

    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
