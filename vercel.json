{
  "version": 2,

  "routes": [
    { "handle": "filesystem" },

    { "src": "^/$", "dest": "/public/index.html" },

    { "src": "^/admin$", "dest": "/admin/index.html" },
    { "src": "^/admin/login$", "dest": "/admin/login/index.html" },
    { "src": "^/admin/setup$", "dest": "/admin/setup/index.html" },

    { "src": "^/xtaagc/admin/dashboard$", "dest": "/xtaagc/admin/dashboard/index.html" },

    { "src": "^/api/(.*)", "dest": "/api/$1" },

    { "src": "/(.*)", "dest": "/public/404.html" }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
