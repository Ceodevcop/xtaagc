{
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/home",
      "destination": "/public/index.html"
    },

    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin/login",
      "destination": "/admin/login/index.html"
    },
    {
      "source": "/admin/setup",
      "destination": "/admin/setup/index.html"
    },

    {
      "source": "/xtaagc/admin/dashboard",
      "destination": "/xtaagc/admin/dashboard/index.html"
    },

    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ],

  "redirects": [
    {
      "source": "/admin/index.html",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/public/index.html",
      "destination": "/",
      "permanent": true
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ],

  "cleanUrls": true,
  "trailingSlash": false
}
